2327,IssuesEvent,2017-04-13 01:10:46+00:00,7106250,spulec/freezegun,292606,spulec,,,closed,freeze_time doesn't freeze time of pytest fixtures,[],[],1,"Following test fails which shows that freeze_time only freezes the time of the test but not of dependent fixtures.

    from datetime import date
    import pytest
    from freezegun import freeze_time

    @pytest.fixture
    def somedate():
        return date.today()

    @freeze_time(""2001-01-01"")
