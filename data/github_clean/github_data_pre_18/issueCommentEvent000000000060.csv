                    evt = evt.originalEvent || evt || window.event; //ie8 fixes
                    var target = evt.target || evt.srcElement;
                    if (promise !== null) {
                        $timeout.cancel(promise);
                    }
                    promise = $timeout(function () {
                        tableCtrl.search(target.value, scope.predicate || '');
                        promise = null;
                    }, throttle);
                });",{},,User,False
