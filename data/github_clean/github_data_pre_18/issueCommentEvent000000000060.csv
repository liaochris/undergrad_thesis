2859,IssueCommentEvent,2016-05-10 04:08:28+00:00,1938370,Mottie/tablesorter,136959,Mottie,,,153740470,218054419,"Hmm, try initializing the sticky headers widget after tablesorter initializes ([demo](http://jsfiddle.net/f36416oy/24/)):

```js
$(function() {

  $('table').tablesorter({
    debug: true,
    theme: 'blue',
    widgets: [], // no widgets
    widgetOptions: {
      stickyHeaders_offset: 50
    },
    initialized: function() {
      // adjust the delay as desired... probably best to have it run after
      // the page has finished loading everything.
      setTimeout(function() {
        // initialize the stickyHeaders widget here
        $('table').trigger('applyWidgetId', 'stickyHeaders');
      }, 2000);
    }
  });

});
```",{},,User,False
