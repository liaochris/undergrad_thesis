11686,IssueCommentEvent,2017-05-19 19:17:30+00:00,7209075,pantsbuild/pants,3946121,youngderekm,3065172,pantsbuild,230065829,302788818,"A small task that dumps out fingerprints/hashes of pieces of the target:

```python

from __future__ import (absolute_import, division, generators, nested_scopes, print_function,
                        unicode_literals, with_statement)

from pants.base.exceptions import TaskError
from pants.task.task import Task
from pants.backend.jvm.tasks.jvm_compile.jvm_compile import ResolvedJarAwareFingerprintStrategy
from pants.source.payload_fields import SourcesField

import os
from hashlib import sha1
from pants.base.build_environment import get_buildroot


class FingerTask(Task):
    # don't cache, as we don't generate artifacts
    @property
    def cache_target_dirs(self):
        return False

    def execute(self):
        for target in self.context.targets():
            print(""target: "" + target.name)
            print(""  invalidation: "" + target.invalidation_hash(None))
            for key in target.payload._fields:
                field = target.payload.get_field(key)
                val = target.payload.get_field_value(key)
                if field:
                    print(""  "" + key + "" -> "" + repr(val) + "": "" + field.fingerprint())
                else:
                    print(""  "" + key + "" -> "" + repr(val))
                if isinstance(field, SourcesField):
                    print(""    rel_path: "" + field.rel_path)
                    print(""    sources: "" + repr(field.sources))
                    print(""    files_hash: "" + repr(field.sources.files_hash))
                    h1 = sha1()
                    for path in sorted(field.sources.files):
                        file_digest = None
                        h = sha1()
                        h.update(path)
                        h1.update(path)
                        name_digest = h.hexdigest()
                        with open(os.path.join(get_buildroot(), field.sources.rel_root, path), 'rb') as f:
                            h = sha1()
                            data = f.read()
                            h.update(data)
                            h1.update(data)
                            file_digest = h.hexdigest()
                        print(""      "" + path + "" "" + name_digest + "" "" + file_digest)
                    print(""      computed: "" + repr(h1.digest()))
```
",{},,User,False
