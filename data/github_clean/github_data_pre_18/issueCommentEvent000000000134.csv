8991,IssueCommentEvent,2016-04-09 03:51:42+00:00,2014929,scikit-image/scikit-image,1315589,soupault,897180,scikit-image,146711608,207695901,"As for MATLAB, unfortunately, I doesn't have CV toolbox.

As for OpenCV, it supports only uint8 images (both color and grayscale), and only L2-Hys for cell normalization. I've implemented L2-Hys inline and used the results on uint8_grayscale for comparison.
Here they are:

```
import numpy as np

import skimage
from skimage import data, color
import _hog as feature

import cv2


if __name__ == ""__main__"":
    img_rgb_float = data.astronaut()
    img_gray_float = color.rgb2gray(img_rgb_float)

    img_gray_uint = skimage.img_as_uint(img_gray_float).astype(np.uint8)
    img = img_gray_uint

    # Parameters
    win_size = img.shape
    win_stride = win_size
    block_size_pixels = (16, 16)
    block_size_cells = (2, 2)
    block_stride = (8, 8)
    cell_size = (8, 8)
    n_bins = 9
    deriv_aperture = False
    win_sigma = -1
    histogram_norm_type = 0
    l2_hys_thr = 0.2
    gamma_correction = False
    n_levels = 64
    padding = (0, 0)
    locations = ()

    # OpenCV
    hog = cv2.HOGDescriptor(win_size,
                            block_size_pixels,
                            block_stride,
                            cell_size,
                            n_bins,
                            deriv_aperture,
                            win_sigma,
                            histogram_norm_type,
                            l2_hys_thr,
                            gamma_correction,
                            n_levels)
    res_opencv = hog.compute(img,
                             win_stride,
                             padding,
                             locations)

    # skimage
    res_skimage = feature.hog(img,
                              orientations=n_bins,
                              pixels_per_cell=cell_size,
                              cells_per_block=block_size_cells,
                              transform_sqrt=gamma_correction)
    res_skimage = res_skimage.reshape(-1, 1)
    
    # Comparison
    print(res_opencv.shape)  
    print(res_skimage.shape)

    neq = res_opencv != res_skimage
    print(np.sum(neq))

    print(np.sum(np.isclose(res_opencv, res_skimage)))
    
    print(res_opencv[neq][:10])
    print(res_skimage[neq][:10])
```
Output:
```
