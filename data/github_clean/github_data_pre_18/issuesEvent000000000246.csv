		--	VALUES (3, @pDate, @pProductID, CAST(@pQtyToIssue AS numeric(18,3)), @pWOID, @pEmpID)

		--	SELECT @pInvTxID = @@IDENTITY
		--END

		INSERT INTO [Work Order BOM] ([WOID], [ProductID], [Qty Required], [Qty Issued], [Qty Remaining], [Complete], [Transaction ID])
		VALUES (@pWOID, @pProductID, @pQtyToIssue, @pQtyToIssue, 0, 1, @pInvTxID)

		SELECT @pWOBOMID = @@IDENTITY


--CREATE WOBOMISSUE TRANSACTION
	INSERT INTO [Work Order BOM Issues] ([WOBOM ID], [Issue Date], [Employee ID], [Qty Issued])
	VALUES (@pWOBOMID, @pDate, @pEmpID, @pQtyToIssue)

	SELECT @pWOBOMIssueID = @@IDENTITY

--MODIFY HOLD TRANSACTION IN OLD INVENTORY TRANSACTIONS TABLE
	--UPDATE [Inventory Transactions]
	--SET [Quantity] = isnull([Quantity], 0) - @pQtyToIssue, [Transaction Modified Date] = @pDate
	--WHERE [Transaction ID] = @pInvTxID

--GET FIFO LAYER dATA
	DECLARE cursor_fifo_layers CURSOR Read_Only

	FOR 
	SELECT [ID], [UnitCost], [QtyOnHand]
	FROM [FIFO Layers]
	WHERE ([QtyOnHand] > 0 AND [ProductID] = @pProductID)
	ORDER BY [CreatedDate], [ID]

	OPEN cursor_fifo_layers

		FETCH NEXT FROM cursor_fifo_layers
		INTO @pFIFOLayerID, @pFIFOUnitCost, @pFIFOQtyOnHand  --This drops you into the 1st record of the recordset (cursor)

		While @@FETCH_STATUS = 0  --W1 --This monitors for the last record of the recordset
		
			BEGIN

				SELECT @pRemoveUntil = @pFIFOQtyOnHand - @pQtyToIssue
				SELECT @pI = 0, @pComplete = 0

				IF @pRemoveUntil < 0 SELECT @pRemoveUntil = 0

			WHILE @pFIFOQtyOnHand <> @pRemoveUntil  --W2

				BEGIN
					SELECT @pFIFOQtyOnHand =  @pFIFOQtyOnHand - 1
					SELECT @pQtyToIssue =  @pQtyToIssue - 1
					SELECT @pI =  @pI + 1
				END

				INSERT INTO [FIFO Transactions] (FIFOLayerID, TypeID, TransactionDate, Qty, WOID, EmpID, WOBOMIssueID, ProductID, UnitCost)
				VALUES (@pFIFOLayerID, 1, @pDate, @pI, @pWOID, @pEmpID, @pWOBOMIssueID, @pProductID, @pFIFOUnitCost)

				IF @pFIFOQtyOnHand = 0
					SELECT @pComplete = 1
		
				UPDATE [FIFO Layers]
				SET [QtyOnHand] = @pFIFOQtyOnHand, Complete = @pComplete
				WHERE (ID = @pFIFOLayerID)	
	
				IF @pQtyToIssue = 0
					RETURN(1)

			FETCH NEXT FROM cursor_fifo_layers
			INTO @pFIFOLayerID, @pFIFOUnitCost, @pFIFOQtyOnHand

			END

	CLOSE cursor_fifo_layers
	Deallocate cursor_fifo_layers

END`


",{},{}
2961,IssuesEvent,2017-02-03 19:38:52+00:00,59235,mkleehammer/pyodbc,1158224,keitherskine,,,opened,PyCodec_Encode error handler in params.cpp,[],[],0,"This is very minor, but within params.cpp, I suspect that the references to `""errors""` in calls to `PyCodec_Encode()` should probably refer to `""strict""` instead.  `""errors""` is not one of the [standard error handlers](https://docs.python.org/3/library/codecs.html#error-handlers). There are two examples of this:
https://github.com/mkleehammer/pyodbc/blob/master/src/params.cpp#L119
https://github.com/mkleehammer/pyodbc/blob/master/src/params.cpp#L167

In those cases, `PyCodec_Encode(param, enc.name, ""errors"")` should probably be `PyCodec_Encode(param, enc.name, ""strict"")`

This would match what is in sqlwchar.h, e.g.:
https://github.com/mkleehammer/pyodbc/blob/master/src/sqlwchar.h#L54

There would be no change in behavior, because, as I understand it, if the bytes cannot be encoded then PyCodec_Encode() will return null whether the error handler can be found or not, but it would be preferable if the code did not refer to a non-existent error handler.
",{},{}
2968,IssuesEvent,2018-05-09 05:40:39+00:00,59235,mkleehammer/pyodbc,17787492,JordanBoltonMN,,,opened,Cannot call SqlGetInfo for most convert info types,[],[],0,"### Environment

- Python: 2.7.14 64b
- pyodbc: 4.0.22
- OS: Windows 10 Enterprise 64b
- DB: Snowflake 64b
- driver: 2.14

### Issue

I am using pyodbc to help diagnose a ODBC driver issue and I'm running into issues with calls to SqlGetInfo.

    conn = pyodbc.connect(connection_string)

    # executes without issues
    conn.getinfo(pyodbc.SQL_CONVERT_VARCHAR) # 70, SQL_CONVERT_VARCHAR in sqlext.h

    # fails, along with every other type of SQL_CONVERT info type
    conn.getinfo(67) # SQL_CONVERT_TIMESTAMP in sqlext.h

This is due to the whitelist of [allowed info types](https://github.com/mkleehammer/pyodbc/blob/master/src/connection.cpp#L506) containing no converts other than varchar. Is there a reason why the other converts cannot be added to `aInfoTypes`?
",{},{}
