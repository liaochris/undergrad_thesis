5763,IssuesEvent,2018-03-06 19:19:39+00:00,4479494,serge-sans-paille/pythran,636199,diorcety,,,opened,Non determinist compilation error?,[],[],0,"Here two function doing exactly the same thing the only difference is the input ""format.
I had very strange behavour on that, sometime it's compile sometime not.
For example the following example it doesn't compile (something related to __pythran_modone::get_new_image_reference::operator())
but if I remove XXX from `# pXXXythran export aabb(int32[][] list, int[][])`, the compiler doesn't complain anymore on get_new_image_reference ????

```
import numpy as np

# pXXXythran export aabb(int32[][] list, int[][])
# pythran export aabb(float32[][] list, int[][])
def aabb(exdata, nflag):
    Nimgs = len(exdata)

    maxflag = int(np.amax(nflag)) + 1 

    if np.any(nflag >= Nimgs):
        raise Exception(""You need %d extra images instead of %d"" % (maxflag, Nimgs))

    imref = exdata[0]

    for j in xrange(1, maxflag):
        imref = np.where(nflag == j, exdata[j], imref)

    return imref


# pythran export get_new_image_reference((int32[][], int[][], int32[][] list, float32[][], int))
# pXXythran export get_new_image_reference((int64[][], int[][], int64[][] list, float32[][], int))
# pXXythran export get_new_image_reference((float32[][], int[][], float32[][] list, float32[][], int))
# pXXythran export get_new_image_reference((float64[][], int[][], float64[][] list, float32[][], int))
def get_new_image_reference(reference):
    _, nflag, exdata, _, _ = reference

    Nimgs = len(exdata)

    maxflag = int(np.amax(nflag)) + 1 

    if np.any(nflag >= Nimgs):
        raise Exception(""You need %d extra images instead of %d"" % (maxflag, Nimgs))

    imref = exdata[0]

    for j in xrange(1, maxflag):
        imref = np.where(nflag == j, exdata[j], imref)

    return imref

```",{},{}
