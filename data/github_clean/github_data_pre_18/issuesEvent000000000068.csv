  tp_iter = 0xdbdbdbdbdbdbdbdb, tp_iternext = 0xdbdbdbdbdbdbdbdb, tp_methods = 0xdbdbdbdbdbdbdbdb, tp_members = 0x3fffb72fada8, tp_getset = 0xa1, tp_base = 0x1115e1e0, tp_dict = 0x3fffb79d0dc0 <main_arena+232>, tp_descr_get = 0x3fffb2d69318,
