15684,IssuesEvent,2018-01-26 04:27:15+00:00,99273369,NeurodataWithoutBorders/pynwb,1616478,ajtritt,12140348,NeurodataWithoutBorders,closed,extension does not take np.ndarray argument,[],[],4,"```python
import numpy as np
import random

from pynwb.spec import NWBDatasetSpec, NWBNamespaceBuilder, NWBGroupSpec
from pynwb import get_class, load_namespaces, NWBFile, NWBHDF5IO

ns_path = ""spikey.namespace.yaml""
ext_source = ""spikey.extensions.yaml""
PopulationSpikeTimes = NWBGroupSpec(doc='Population Spike Times',
                                      datasets=[
                                          NWBDatasetSpec(doc='spike times for all neurons', 
                                                         shape=(1,), 
                                                         name='times', dtype='float'),
                                          NWBDatasetSpec(doc='data pointer', 
                                                         shape=(1,),
                                                         name='data_pointer', dtype='int')
                             ],
                           neurodata_type_def='PopulationSpikeTimes',
                           neurodata_type_inc='NWBContainer')
ns_builder = NWBNamespaceBuilder('spikey extensions', ""spikey"")
ns_builder.add_spec(ext_source, PopulationSpikeTimes)
ns_builder.export(ns_path)

# generate fake data
duration = 10
nspikes = 1000
nunits = 5

times = np.random.rand(nspikes) * duration
data_pointer = np.sort(random.sample(range(len(times)), nunits))

## pull types from yaml files
load_namespaces(ns_path)
PopulationSpikeTimes = get_class('PopulationSpikeTimes', 'spikey')

pop_data = PopulationSpikeTimes(name='example population', source='source',
                                                          times=times, data_pointer=data_pointer)
```
gives the following error:

```python
---------------------------------------------------------------------------
TypeError                                 Traceback (most recent call last)
<ipython-input-46-eb8a530669b8> in <module>()
      3 PopulationSpikeTimes = get_class('PopulationSpikeTimes', 'spikey')
      4 
----> 5 pop_data = PopulationSpikeTimes(name='example population', source='source', times=times, data_pointer=data_pointer)
      6 
      7 

~/anaconda3/lib/python3.6/site-packages/pynwb/form/utils.py in func_call(*args, **kwargs)
    303                 if parse_err:
    304                     msg = ', '.join(parse_err)
--> 305                     raise_from(TypeError(msg), None)
    306                 return func(self, **parsed['args'])
    307         else:

~/anaconda3/lib/python3.6/site-packages/six.py in raise_from(value, from_value)

TypeError: incorrect type for 'times' (got 'ndarray', expected 'list, tuple, dict or set'), incorrect type for 'data_pointer' (got 'ndarray', expected 'list, tuple, dict or set')
```
I can convert the ndarray into a list in this case and avoid the error, but I feel like this extension should be able to accept a list
### Environment
Please describe your environment according to the following bullet points.
- **Python Executable:** Conda
