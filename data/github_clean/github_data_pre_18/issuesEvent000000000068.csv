   333            before overwriting its storage */                                                                                                                                                                                                  
   334         if (type->ob_base.ob_base._ob_next) {                                                                                                                                                                                                 
  >335             _Py_ForgetReference((PyObject*)type);                                                                                                                                                                                             
   336         }                                                                                                                                                                                                                                     
   337     #endif                                                                                                                                                                                                                                    



1749    void                                                                                                                                                                                                                                      
   1750    _Py_ForgetReference(PyObject *op)                                                                                                                                                                                                         
   1751    {                                                                                                                                                                                                                                         
   1752    #ifdef SLOW_UNREF_CHECK                                                                                                                                                                                                                   
   1753        PyObject *p;                                                                                                                                                                                                                          
   1754    #endif                                                                                                                                                                                                                                    
   1755        if (op->ob_refcnt < 0)                                                                                                                                                                                                                
  >1756            Py_FatalError(""UNREF negative refcnt"");                                                                                                                                                                                           
   1757        if (op == &refchain ||                                                                                                                                                                                                                
   1758            op->_ob_prev->_ob_next != op || op->_ob_next->_ob_prev != op) {                                                                                                                                                                   
   1759            fprintf(stderr, ""* ob\n"");                                                                                                                                                                                                        
   1760            _PyObject_Dump(op);                                                                                                                                                                                                               
   1761            fprintf(stderr, ""* op->_ob_prev->_ob_next\n"");                                                                                                                                                                                    
   1762            _PyObject_Dump(op->_ob_prev->_ob_next);                                                                                                                                                                                           
   1763            fprintf(stderr, ""* op->_ob_next->_ob_prev\n"");                                                                                                                                                                                    
   1764            _PyObject_Dump(op->_ob_next->_ob_prev);                                                                                                                                                                                           
   1765            Py_FatalError(""UNREF invalid object"");                                                                                                                                                                                            
   1766        }                                                            
```

Basically the InitType2 is triggering a Py_ForgetReference, but the new’d PyTypeObject is filled with junk for whatever reason.  So Py_ForgetReference blows up.

I guess this is some kind of fundamental ref-counting problem that never turned up in before because regular Python doesn’t have Py_TRACE_REFS compiled in.


What actually triggers it is:
```
import h2oaicore
```
The python actual code this ran that triggered the failure is below:

```
def open_dt(path: str, columns: List[str] = None):
    ntrials = 10
    for trial in range(ntrials):
        try:
            if columns is None:
                print(""TOM: "" + path)
                return dt.open(path)    # <<<<<<<<<<<< FAILS
            else:
                return dt.open(path)[columns]
        except Exception as e:
            print_debug(str(e))
            print_debug(""trial #{} in open_dt: temporarily unable to open {}"".format(trial, path))
            sleep(0.2)
            if trial == ntrials - 1:
                raise
```


So probably doing just about anything using datatable and a debug python build will trigger this.
