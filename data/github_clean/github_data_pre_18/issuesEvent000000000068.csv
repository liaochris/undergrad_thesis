              <th st-sort=""reconditioningCost"">ReconditioningCost</th>
              <th st-sort=""otherCost"">OtherCost</th>
              <th st-sort=""sellingPrice"">SellingPrice</th>
            </tr>

          </thead>
          <tbody>
            <tr data-ng-repeat=""row in displayedCollection"">
              <td>{{ row.inventoryTypeName }}</td>
              <td>{{ row.model }}</td>
              <td><a class=""text-info ng-binding"" ui-sref=""app.inventories.edit.basic({inventoryId:inventory.inventoryId})"">{{ row.vin }}</a></td>
              <td>{{ row.miles }}</td>
              <td>{{ row.stockNumber }}</td>
              <td>{{ row.inventoryDate | date : 'MM/dd/yyyy' }}</td>
              <td>{{ row.dealerCost }}</td>
              <td>{{ row.reconditioningCost }}</td>
              <td>{{ row.otherCost }}</td>
              <td>{{ row.sellingPrice }}</td>
            </tr>
          </tbody>
        </table>


Here is the JS

(function () {
  'use strict';

  angular
      .module(""app"")
      .controller('inventoryCtrl', ['$scope', '$state', '$filter', 'inventoryResource', 'inventorySearchResource', InventoryCtrl]);

  function InventoryCtrl($scope, $state, $filter, inventoryResource, inventorySearchResource) {
    
    $scope.rowCollection = [];
    $scope.displayedCollection = [].concat($scope.rowCollection);

    $scope.inventoriesearchResource = inventorySearchResource;
    $scope.filters = {
      searchBy: 'Search By',
      searchFor: ''
    };

    if ($state.params.searchBy && $state.params.searchFor) {
      $scope.filters.searchBy = $state.params.searchBy;
      $scope.filters.searchFor = $state.params.searchFor;
    }

    $scope.setSearchBy = function (serachBy) {
      $scope.filters.searchBy = serachBy;
    };

    $scope.filterData = function () {      
      var searchBy = ($scope.filters.searchBy) ? $scope.filters.searchBy : '';
      var searchFor = ($scope.filters.searchFor) ? $scope.filters.searchFor : '';

      if (searchBy && searchFor) {
        inventorySearchResource.query({ searchBy: searchBy, searchFor: searchFor },function (data) {
          $scope.rowCollection = data;
          $scope.displayedCollection = [].concat($scope.rowCollection);
        });
      }
      else {
        inventoryResource.query(function (data) {
          $scope.rowCollection = data;
          $scope.displayedCollection = [].concat($scope.rowCollection);
        });
        
      }

    };

    $scope.addNewInventory = function () {
      $state.go(""app.inventories.edit.basic"");
    };

    $scope.addNewInventory = function (param) {
      $state.go(""app.inventories.edit.basic"", { inventoryId: param.inventoryId })
    };

    $scope.filterData();

  }
})();

