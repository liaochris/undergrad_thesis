        encode12 = F.relu(self.conv12(encode11))
        encode13 = F.relu(self.conv13(encode12))
        encode14 = F.relu(self.conv14(encode13))
        encode15 = F.relu(self.conv15(encode14))

        decode00 = encode15

        decode01 = F.relu(self.deconv01(decode00))
