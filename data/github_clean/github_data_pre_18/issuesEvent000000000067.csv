    for f in glob.glob(os.path.join(os.path.dirname(__file__), 'app/*.py')):
        z.write(os.path.abspath(f), os.path.basename(f))
buf.seek(0)
pkg = base64.b64encode(buf.read())

client = boto3.client('lambda')
