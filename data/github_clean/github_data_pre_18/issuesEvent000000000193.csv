1131,IssuesEvent,2016-06-14 03:36:45+00:00,38793780,nickoala/telepot,19921125,YielShelion,,,opened,Run multiple bot in one instance?,[],[],0,"I tried making two bot run in one go. but I got Error 409
TelegramError: (u'Conflict: terminated by other long poll or webhook', 409, {u'error_code': 409, u'ok': False, u'description': u'Conflict: terminated by other long poll or webhook'})

How do I fix this?
I am really new to this and I don't know what webhook is and how I set one...

```
import telepot
import time

def handleeq(msg):
    content_type, chat_type, chat_id = telepot.glance(msg)
    command2 = None #msg['text']
    try:
        if (content_type == 'text'):
            command2 = msg['text']
        chat_id = msg['chat']['id']
        if command2 == '/help':
            boteq.sendMessage(chat_id, 'this is boteq')
            print('TELEGRAM EQ bot - Got command: %s from chat_id %d' % (command2,chat_id))
        elif (command2 == '/eq') or (command2 == '/eq@PSO2EQBot'):
            bot.sendMessage(chat_id, ""Bot EQ is responding"")
            print('TELEGRAM EQ bot - Got command: %s from chat_id %d' % (command2,chat_id))
    except:
        pass
        
boteq = telepot.Bot('tokeneq')
boteq.message_loop(handleeq)


def handlegc(msg):
    content_type, chat_type, chat_id = telepot.glance(msg)
    # from_first_name, from_last_name = telepot.glance(msg)
    global response
    response = botgc.getUpdates()
    try:
        strmsg = msg['text']
        command2 = msg['text']
        sender1 = response[0][u'message'][u'from'].get(u'first_name')
        sender2 = response[0][u'message'][u'from'].get(u'last_name')
    except:
        pass
    try: 
        if (content_type == 'text'):
            strmsg = msg['text']
        else:
            strmsg = ""   Sent a %s"" % content_type
        sender1 = response[0][u'message'][u'from'].get(u'first_name')
        sender2 = response[0][u'message'][u'from'].get(u'last_name')
        print(""[GlobalChat] (botgc) <%s %s> %s"" % (sender1,sender2,strmsg))
        stringtosend = ""[FD] <%s %s> %s"" % (sender1,sender2,strmsg)
        botgc.sendMessage(chat_id,stringtosend)
    except:
        pass
            
botgc = telepot.Bot('tokenGC')
botgc.message_loop(handlegc)

while 1:
    time.sleep(10)
```",{},{}
