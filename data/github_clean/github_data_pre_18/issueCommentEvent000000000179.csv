	option          clitcpka
    default_backend be_db_ro

frontend backup_db_ro
    bind 10.10.0.68:15433
	option          clitcpka
    default_backend be_db_ro

backend be_db_ro
    option httpchk GET /replica
    http-check expect status 200
    balance roundrobin
