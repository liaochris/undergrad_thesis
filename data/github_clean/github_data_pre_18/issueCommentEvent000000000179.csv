3780,IssueCommentEvent,2018-01-04 14:49:22+00:00,60273704,mozilla/DeepSpeech,5239020,pikumar,131524,mozilla,276743553,355300915,"This is the first time I am using deepspeech. Perhaps one wants to modify the deepspeech python executable to check for input type: (Only tested on python 3.6+ubuntu+python-magic installed)

```python
# -*- coding: utf-8 -*-
import re
import sys
import magic # Install python-magic for this. Tested on python 3.6

from deepspeech.client import main

if __name__ == '__main__':
    if len(sys.argv) < 3:
        print(""Not enough arguments!"")
        sys.exit(1)
    itype = magic.from_file(sys.argv[2])
    if ""16 "" not in itype:
        print(""Error: Please encode your input file to 16000Hz"")
        sys.exit(1)
    else:
        print(""Input:"", itype)
    sys.argv[0] = re.sub(r'(-script\.pyw?|\.exe)?$', '', sys.argv[0])
    sys.exit(main())
```",{},NONE,User,False
