1901,IssueCommentEvent,2017-07-20 08:48:59+00:00,48115405,wichert/pyramid_jwt,862603,crooksey,,,244087920,316639339,"No, its not, here is an overview of my settings:

```
def add_role_principals(userid, request):
        roles = []
        import pdb ; pdb.set_trace()
        for item in request.jwt_claims['sub']:
                if item == True:
                        roles.append(item)
        return ['role:%s' % role for role in roles]

def main(global_config, **settings):
        """""" This function returns a Pyramid WSGI application.
        """"""
        config = Configurator(settings=settings,  root_factory='.security.RootACL')
        config.include('.cors')
        config.add_cors_preflight_handler()

        # Enable JWT - JSON Web Token based authentication
        config.set_authorization_policy(ACLAuthorizationPolicy())
        config.include('pyramid_jwt')
        config.set_jwt_authentication_policy('secret200', http_header='Authorization', 
                                                callback=add_role_principals)
        

        # configure custom JSON renderers 
        json_renderer = JSON()
        json_renderer.add_adapter(datetime.date, datetime_adapter)
        json_renderer.add_adapter(Decimal, decimal_adapter)
        config.add_renderer('json_custom', json_renderer)
        # Load model files
        config.include('.models')

        # Customer Info JSON
        config.add_route('get_customer_name', '/customerinfo/name.json')

        config.scan()
        return config.make_wsgi_app()
```",{},,User,False
