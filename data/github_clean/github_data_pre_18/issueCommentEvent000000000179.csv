	timeout client 60m
	timeout connect 10s
	timeout server 60m
	timeout check 5s
    server sql1 10.10.0.70:15432 maxconn 500 check port 8008
    server sql2 10.10.0.71:15432 maxconn 500 check port 8008
    server sql3 10.10.0.72:15432 maxconn 500 check port 8008

frontend ft_db_ro
