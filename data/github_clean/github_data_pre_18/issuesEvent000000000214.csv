226,IssuesEvent,2017-03-06 16:45:49+00:00,65468547,jd/tenacity,2644,jd,,,closed,Provide a context manager,"[{'id': 423198547, 'url': 'https://api.github.com/repos/jd/tenacity/labels/enhancement', 'name': 'enhancement', 'color': '84b6eb', 'default': True}]",[],2,"I like the idea from https://github.com/bhearsum/redo to have `retrying` contextmanager:

```python
from tenacity import retry
from tenacity.stop import stop_after_attempt


@contextmanager
def retrying(func, *retry_args, **retry_kwargs):
    yield retry(*retry_args, **retry_kwargs)(func)


def foo(max_count):
    global count
    count += 1
    print(count)
    if count < max_count:
        raise ValueError(""count too small"")
    return ""success!""

count = 0
ret = None
max_attempt=5
with retrying(foo, stop=stop_after_attempt(max_attempt)) as f:
    ret = f(3)
print(ret)
```

Do you think is may be included in the `tenacity`? I have no clue if it works with `async` and `futures`.",{},{}
267,IssuesEvent,2018-05-04 03:34:42+00:00,95191952,rainx/pytdx,37877812,happydig,,,opened,修改了make_sig函数，记录在这里了,[],[],0,"没有制作pull_request, 也感谢rainx的无私奉献！

#!/usr/bin/env python3
import sys
import struct
from shutil import copyfile
def make_sig(seed):
    sig = b''
    bseed = seed.encode('utf-8')
    a = 0x55e
    tl = [(x, y) for x in range(64, 91) for y in range(91, 64, -1)]
    for c in bseed:
        c = c ^ (a >> 0x8)
        a = (0x207f * (a + c) - 0x523d) & 0xffff
        for j, k in tl:
            tmp = 1755 + c - k
            if tmp % 26 == 0 and tmp // 26 == j:
                sig += struct.pack(‘bb’, j, k)
                break
    return sig

if __name__ == '__main__':
    account, tradedll = sys.argv[1], sys.argv[2]
    acce = account[::2]
    sig = make_sig(acce, tradedll)
    targetdll = f'./xtrade{acce}.dll'
    copyfile(tradedll, targetdll)
    with open(targetdll, 'r+b') as f:
      f.seek(1132713)
      f.write(sig)",{},{}
