class MedicationLogItemRowInline(nested_admin.NestedTabularInline):
    model = MedicationLogItemRow
    extra = 1

class MedicationLogItemInline(nested_admin.NestedTabularInline):
    model = MedicationLogItem
    inlines = [
        MedicationLogItemRowInline,
    ]
    extra = 1

    def save_formset(self, request, form, formset, change):
        formset.save()
        for f in formset.forms:
            obj = f.instance
            if obj.pk:
                if 'field_1' in form.changed_data:
                    obj.field_updated_by = request.user        

class MedicationLogAdmin(nested_admin.NestedModelAdmin):
    inlines = [
        MedicationLogItemInline,
    ]
```",{},{}
