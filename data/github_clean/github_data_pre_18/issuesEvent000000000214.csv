 kit/__init.py"", line 77, in mavlink_thread
 fn(self)
 File ""/usr/local/lib/python2.7/dist-packages/dronekit-2.0.0rc7-py2.7.egg/drone
 kit/lib/init.py"", line 855, in listener
 raise Exception('>>> No heartbeat in %s seconds, aborting.' % self._heartbea
