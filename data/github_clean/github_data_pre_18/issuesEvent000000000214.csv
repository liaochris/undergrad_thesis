  File ""/home/maxence/lumby/lumby-storage/ENV/site-packages/zmq/sugar/socket.py"", line 392, in send
    return super(Socket, self).send(data, flags=flags, copy=copy, track=track)
  File ""/home/maxence/lumby/lumby-storage/ENV/site-packages/zmq/backend/cffi/socket.py"", line 209, in send
    c_message = ffi.new('char[]', message)
  File ""/home/maxence/sources/pypy3-v6.0.0-linux64/lib_pypy/cffi/api.py"", line 258, in new
    return self._backend.newp(cdecl, init)
TypeError: expected new array length or list/tuple/str, not bytearray
```
