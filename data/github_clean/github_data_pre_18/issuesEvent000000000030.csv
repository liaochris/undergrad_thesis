myarr = []

mydict = {}
mydict['KV'] = {}
mydict['KV']['Key'] = consul_prefix + ""/1.txt""
mydict['KV']['Value'] = ""11.txt""
mydict['KV']['Verb'] = ""set""
myarr.append(mydict)


mydict = {}
mydict['KV'] = {}
mydict['KV']['Key'] = consul_prefix + ""/2.txt""
mydict['KV']['Value'] = ""12.txt""
mydict['KV']['Verb'] = ""set""
