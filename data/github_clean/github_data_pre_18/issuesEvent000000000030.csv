7391,IssuesEvent,2018-03-30 12:06:08+00:00,6930489,facebook/watchman,358809,roxlu,69631,facebook,opened,Build Watchman from source on Mac ,[],[],0,"When you don't use brew on Mac you can use the following script to setup a tiny dev. environment which allows you to build and install watchman.

```
#!/bin/sh

# A self contained shell script that will setup a tiny environment that is
# necessary to build Watchman on Mac. Tested on Mac 10.13.2 but should work
# fine on any version.
#
# This script will install watchman in your global directories. If you don't
# want this add `--prefix=SOME_DIR` at the bottom where we call `./configure`.
#
# This scripts can be found at: https://gist.github.com/roxlu/268f733db838f945a8ea3209674cd196

d=${PWD}
sd=${d}/sources
id=${d}/installed

export PATH=""${id}/bin:${PATH}""
export CFLAGS=""-I${id}/include/ -m64 -arch x86_64""
export CPPFLAGS=${CFLAGS}
export CXXFLAGS=${CFLAGS}
export LDFLAGS=""-L${id}/lib/ ""

autoconf_version=""2.69""
automake_version=""1.16""
libtool_version=""2.4.6""
pkgconfig_version=""0.28""  # 0.29 does not compile on Mac 10.13.2

if [ ! -d ${sd} ] ; then
    mkdir ${sd}
fi

# maketools
if [ ! -d ${sd}/autoconf-${autoconf_version} ] ; then
    cd ${sd}
    curl -L -o autoconf.tar.gz http://ftp.gnu.org/gnu/autoconf/autoconf-${autoconf_version}.tar.gz
    tar -zxvf autoconf.tar.gz
    cd autoconf-${autoconf_version}
    ./configure --prefix=${id}
    make
    make install
fi

# automake
if [ ! -d ${sd}/automake-${automake_version} ] ; then
    cd ${sd}
    curl -L -o automake.tar.gz http://ftp.gnu.org/gnu/automake/automake-${automake_version}.tar.gz
    tar -zxvf automake.tar.gz
    cd automake-${automake_version}
    ./configure --prefix=${id}
    make
    make install
fi

# libtool
if [ ! -d ${sd}/libtool-${libtool_version} ] ; then
    cd ${sd}
    curl -L -o libtool.tar.gz http://ftpmirror.gnu.org/libtool/libtool-${libtool_version}.tar.gz
    tar -zxvf libtool.tar.gz
    cd libtool-${libtool_version}
    ./configure --prefix=${id}
    make
    make install
fi

# pkg-config
if [ ! -d ${sd}/pkg-config-${pkgconfig_version} ] ; then
    cd ${sd}
    curl -L -o pkg-config.tar.gz https://pkg-config.freedesktop.org/releases/pkg-config-${pkgconfig_version}.tar.gz
    tar -zxvf pkg-config.tar.gz
    cd pkg-config-${pkgconfig_version}
    ./configure --prefix=${id} --with-internal-glib
    make
    make install
fi

# watchman
if [ ! -d ${sd}/watchman ] ; then
    cd ${sd}
    git clone https://github.com/facebook/watchman.git
    cd watchman
    echo ""ok...""
    ./autogen.sh
    ./configure 
    make
    sudo make install
fi

```",{},{}
