	typename SUBNET
>
using hourglass = add_prev8<hgup<skip1<			\
	tag8<convBlock<256,add_prev7<hgup<skip2<	\
	tag7<convBlock<256,add_prev6<hgup<skip3<	\
	tag6<convBlock<256,add_prev5<hgup<skip4<	\
	tag5<hglowup<convBlock<256, hglow<			\
