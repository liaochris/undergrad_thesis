# event_notifier - sets up event loops for a device

class event_notifier():

	def __init__(self, factory, device):
		self.factory = factory
		self.device = device
		self.sub1 = device.renderingControl.subscribe()
		self.sub2 = device.avTransport.subscribe()
		reactor.callWhenRunning(self.startup1)
		reactor.callWhenRunning(self.startup2)
		reactor.addSystemEventTrigger('before', 'shutdown', self.cleanup)

	def cleanup(self):
		print self.device.uid, 'shutting down event notifers'
		self.sub1.unsubscribe()
		self.sub2.unsubscribe()
