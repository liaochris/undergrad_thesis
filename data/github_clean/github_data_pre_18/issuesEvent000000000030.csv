13310,IssuesEvent,2015-08-26 08:49:03+00:00,12235583,elastic/curator,11554372,abo-adapt,6764390,elastic,opened,Don't use --timestring when command is snapshot,[],[],0,"Currently snapshot cronjobs get --timestring added. This results in curator giving a warning that --timestring is used, but neither --newer-than nor --older-than is used. This prevents the command from actually executing through cron. This simple patch fixes that:

--- a/modules/curator/manifests/job.pp
+++ b/modules/curator/manifests/job.pp
@@ -81,7 +81,11 @@ define curator::job (
     $_regex = undef
   }

-  $_timestring = ""--timestring '${timestring}'""
+  if ($command == ""snapshot"") {
+    $_timestring = undef
+  else {
+    $_timestring = ""--timestring '${timestring}'""
+  }
",{},{}
