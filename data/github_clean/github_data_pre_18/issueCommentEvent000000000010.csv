5110,IssueCommentEvent,2016-05-30 02:29:18+00:00,36964309,jantman/awslimitchecker,11064353,sbasgall,,,138966459,222400110,"I am doing something similar with a wrapper script using AWS Lambda to push metrics for current limits and usage to a graphite server.

```python
import logging

from awslimitchecker.checker import AwsLimitChecker

import graphitesend


def main(event, context):
    """"""Collect and send AWS Limits to Hosted Graphite.

    Keyword arguments:
    event -- JSON Payload from Cloudwatch Event
	{
		""hg_config"": {
			""key"": ""hosted_graphite api key"",
			""domain"": ""carbon.hostedgraphite.com"",
      ""system_name"": ""awslimits""
		},
		""limits_config"": {
			""region"": ""us-east-1"",
			""account"": ""build"",
			""use_ta"": ""True""
		}
	}
    context -- Runtime information object from Lambda service

    Returns:
    None""""""

    logger = logging.getLogger()
    logger.setLevel(logging.ERROR)

    g_obj = graphitesend.init(
        graphite_server=event['hg_config']['domain'],
        prefix=event['hg_config']['key'],
        system_name=event['hg_config']['system_name'],
        autoreconnect=True,
        asynchronous=True,
        lowercase_metric_names=True,
        clean_metric_name=False,
    )

    use_ta = event['limits_config']['use_ta']
    region = event['limits_config']['region']
    account = event['limits_config']['account']

    checker = AwsLimitChecker(region=region)
    checker.find_usage(use_ta=use_ta)

    for service, svc_limits in sorted(checker.get_limits(use_ta=use_ta).items()):

        base_path = '.'.join([account, region, service])

        for limit_name, limit in sorted(svc_limits.items()):

            limit_metric = limit.get_limit()
            clean_limit_name = limit_name.replace(' ', '-').replace('.', '_')
            limit_path = '.'.join([base_path, clean_limit_name])

            for resource in limit.get_current_usage():

                limit_path_res = '.'.join([limit_path, resource.resource_id])

                if resource.resource_id:
                    g_obj.send(""."".join([limit_path_res, 'limit']), limit_metric)
                    g_obj.send(""."".join([limit_path_res, 'current']), resource.get_value())
                else:
                    g_obj.send(""."".join([limit_path, 'limit']), limit_metric)
                    g_obj.send(""."".join([limit_path, 'current']), resource.get_value())
```

Maybe it is appropriate to include this feature as an example script instead of an awslimitchecker program feature?
",{},,User,False
