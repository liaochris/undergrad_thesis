```
def use_aiojob(app):
    def decorator(func):
        @functools.wraps(func)
        async def wrapper(*args, **kw):
            scheduler = app['siojobs']
            job = await scheduler.spawn(func(*args, **kw))
            return await job.wait()
        return wrapper
    return decorator
```

