    threadNA = collecterThread(3, ""Søren Bjerg"", ""NA"", ""7.22"")
    threadEU = collecterThread(4, ""FNC Rekkles"", ""EUW"", ""7.22"")

    threadJP.start()
    threadKR.start()
    threadNA.start()
    threadEU.start()
