        const rs2_raw_data_buffer* receiveBuffer;
        if (!master) {
            receiveBuffer = rs2_send_and_receive_raw_data(d.get(), (void*)syncMaster, syncLength, &e);
            master = true;
        } else {
            receiveBuffer = rs2_send_and_receive_raw_data(d.get(), (void*)syncSlave, syncLength, &e);
        }
        if (e) {
            errors = true;
            cout << rs2_get_error_message(e) << "" "";
            rs2_free_error(e);
            e = nullptr;
        }
        rs2_delete_raw_data(receiveBuffer);
    }
    if (errors) {
        cout << endl;
    } else {
        cout << ""Ok"" << endl;
    }
```

[main.zip](https://github.com/IntelRealSense/librealsense/files/2098864/main.zip)
