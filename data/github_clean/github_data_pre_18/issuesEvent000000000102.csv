#response = """"
# Print an example of getting custom response

response = bot.get_response(""^How can I help u"")
print(response)
######################################################################

from chatterbot.logic import LogicAdapter

class MyLogicAdapter(LogicAdapter):
    def __init__(self, **kwargs):
        super(MyLogicAdapter, self).__init__(**kwargs)

    def can_process(self, statement):
        if statement.text.startswith('^'):
                return True
        else:
                return False
    def process(self, statement):
        from chatterbot.conversation import Statement
        import requests

        # Make a request to the temperature API
        #response = requests.get('http://api.temperature.com/current?units=celsius')
        response = requests.get('http://localhost:8983/solr/search/select?indent=on&q=*:*&wt=json')
        data = response.json()
