    result = func(self)
  File ""/home/forcer/.virtualenvs/elpy/local/lib/python2.7/site-packages/jedi/parser/representation.py"", line 1183, in expression_list
    call = cls(self._sub_module, tok_str, tok.start_pos, tok.end_pos, self)
