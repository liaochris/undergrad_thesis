12447,IssuesEvent,2016-08-01 11:54:18+00:00,12968651,pgmpy/pgmpy,1049925,jamieforth,5500131,pgmpy,opened,DBNInference error with minimal graph,[],[],0,"Hi,

I am trying to become familiar with the DBN inference capabilities of pgmpy, and have run into a problem that seems related to PR #663 (DBN initialze_intial_state method).

I am currently at commit e85706c9.

Based on the example in PR #663:

```
from pgmpy.factors import TabularCPD
from pgmpy.models import DynamicBayesianNetwork as DBN
from pgmpy.inference import DBNInference

model = DBN()

model.add_edges_from([(('a', 0), ('b', 1)), (('c', 0), ('b', 1))])

a_cpd = TabularCPD(('a', 0), 2, [[0.5, 0.5]])

c_cpd = TabularCPD(('c', 0), 2, [[0.5, 0.5]])

b_cpd = TabularCPD(('b', 1), 2, [[0.5, 0.5, 0.5, 0.5],
                                 [0.5, 0.5, 0.5, 0.5]],
                   [('c', 0), ('a', 0)], [2, 2])

model.add_cpds(a_cpd, c_cpd, b_cpd)
model.initialize_initial_state()

dbn_inf = DBNInference(model)
```

Results in `ValueError: ('CPD defined on variable not in the model', <TabularCPD representing P(('a', 0):2) at 0x7efe297007d0>)`

```
/home/jamie/src/python/src/pgmpy/pgmpy/inference/dbn_inference.pyc in 
__init__(self, model)
     64         query
     65         """"""
---> 66         super(DBNInference, self).__init__(model)
     67         self.interface_nodes_0 = 
model.get_interface_nodes(time_slice=0)
     68         self.interface_nodes_1 = 
model.get_interface_nodes(time_slice=1)

/home/jamie/src/python/src/pgmpy/pgmpy/utils/state_name.pyc in 
wrapper(*args, **kwargs)
     38                 args[0].state_names = kwargs['state_names']
     39                 del kwargs['state_names']
---> 40             f(*args, **kwargs)
     41         return wrapper
     42 

/home/jamie/src/python/src/pgmpy/pgmpy/inference/base.pyc in __init__(self, 
model)
     86         elif isinstance(model, DynamicBayesianNetwork):
     87             self.start_bayesian_model = 
BayesianModel(model.get_intra_edges(0))
---> 88             
self.start_bayesian_model.add_cpds(*model.get_cpds(time_slice=0))
     89             cpd_inter = [model.get_cpds(node) for node in 
model.get_interface_nodes(1)]
     90             self.interface_nodes = model.get_interface_nodes(0)

/home/jamie/src/python/src/pgmpy/pgmpy/models/BayesianModel.pyc in 
add_cpds(self, *cpds)
    157             if set(cpd.variables) - set(cpd.variables).intersection(
    158                     set(self.nodes())):
--> 159                 raise ValueError('CPD defined on variable not in 
the model', cpd)
    160 
