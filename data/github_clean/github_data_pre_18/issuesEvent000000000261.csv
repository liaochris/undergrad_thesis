```
import os
import mxnet as mx

def test_ctx_group():
    data = mx.symbol.Variable('data')
    out  = mx.symbol.broadcast_add(data, data)
    texec = out.simple_bind(mx.cpu(0), data=(1,200))
    print(""done"")

if __name__ == '__main__':
    test_ctx_group()
```

