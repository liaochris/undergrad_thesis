  File ""/Users/sbailey/anaconda/envs/py3/lib/python3.5/site-packages/fitsio/fitslib.py"", line 3657, in npy_num2fits
    raise ValueError(""unsupported type '%s'"" % npy_dtype)
ValueError: unsupported type 'U5'
```

Although it is true that the FITS format doesn't natively know about unicode, it seems that we should do something to be able to support the native string type of python3.  e.g. for consideration:
* downcast the unicode str to bytes upon writing and only raise an exception if the array contains non-ASCII unicode characters that can't be downcast.
* provide a `native_string` option to `fitsio.read` that would cast any FITS strings to the native string type for that version of python (py2.x: str=bytes='Sn', py3.x: str=unicode='Un')

That still seems clumsy but python 3 and native str=unicode is in our future whether we like it or not, so having some sort of support for it would be very handy.  A more formally correct solution would be to actually encode/decode the unicode and include in the header metadata what the encoding method is, but that starts to tread on the territory of standards (or at least registered conventions...).

If anyone reading this has been part of IAU FITS standard definition discussions and knows if there are specific guidelines or conventions for this already, please let us know.

The tests:
```python
#- unit tests of fitsio with strings
#- Stephen Bailey, Lawrence Berkeley Lab

from __future__ import unicode_literals

import unittest
from uuid import uuid4
import os

import numpy as np
import fitsio

class _TestTable(unittest.TestCase):
    '''
    Base class for testing FITS tables.

    Subclass this and add setupClass to define self.data to test
    '''

    def setUp(self):
        self.testfile = 'test-{}.fits'.format(uuid4())

    def tearDown(self):
        if os.path.exists(self.testfile):
            os.remove(self.testfile)

    def test_io_strict(self):
        '''test I/O roundtrip with strict matching'''
        fitsio.write(self.testfile, self.data)
        dx = fitsio.read(self.testfile)
        self.assertEqual(self.data['x'].dtype, dx['x'].dtype)
        self.assertEqual(self.data['y'].dtype, dx['y'].dtype)
        self.assertTrue(np.all(self.data['x'] == dx['x']), 'x: {} != {}'.format(self.data['x'], dx['x']))
        self.assertTrue(np.all(self.data['y'] == dx['y']), 'y: {} != {}'.format(self.data['y'], dx['y']))

    def test_io_loose(self):
        '''test I/O roundtrip while ignoring trailing whitespace'''
        fitsio.write(self.testfile, self.data)
        dx = fitsio.read(self.testfile)
        self.assertEqual(self.data['x'].dtype, dx['x'].dtype)
        self.assertEqual(self.data['y'].dtype, dx['y'].dtype)
        #- Cast to chararray to strip trailing whitespace
        x = dx['x'].view(np.chararray)
        y = dx['y'].view(np.chararray)
        self.assertTrue(np.all(self.data['x'] == x), 'x: {} != {}'.format(self.data['x'], x))
        self.assertTrue(np.all(self.data['y'] == y), 'y: {} != {}'.format(self.data['y'], y))
    
class TestTable1DColumn(_TestTable):
    @classmethod
    def setUpClass(cls):
        dtype = [
            (str('x'), (str, 5)),    #- 1D column of 5-character strings
            (str('y'), (str, 3)),    #- !D column of 3-character strings
        ]
        data = np.zeros(2, dtype=dtype)
        data['x'] = ['abcde', 'xyz']
        data['y'] = ['A', 'BCX']
        cls.data = data

class TestTable2DColumn(_TestTable):
    @classmethod
    def setUpClass(cls):
        dtype = [
            (str('x'), (str, 5)),        #- 1D column of 5-character strings
            (str('y'), (str, 3), (4,)),  #- 2D column; each row is four 3-char strings
        ]
        data = np.zeros(2, dtype=dtype)
        data['x'] = ['abcde', 'xyz']
        data['y'][0] = ['A', 'BC', 'DEF', '123']
        data['y'][1] = ['X', 'YZ', 'PQR', '999']
        cls.data = data
                
if __name__ == '__main__':
    ### unittest.main()
    t1 = unittest.defaultTestLoader.loadTestsFromTestCase(TestTable1DColumn)
    t2 = unittest.defaultTestLoader.loadTestsFromTestCase(TestTable2DColumn)
    unittest.TextTestRunner(verbosity=2).run(unittest.TestSuite([t1,t2]))
```",{},{}
