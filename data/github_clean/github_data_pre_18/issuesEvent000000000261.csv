1226,IssuesEvent,2016-12-14 20:13:08+00:00,16331291,davisking/dlib,6259399,davisking,,,closed,Some notes on Dlib building - macOS with CUDA&cuDNN,[],[],1,"1. Make sure that Xcode command line tools are installed on your system:
```bash
$ xcode-select --install
```

2. NVCC does not support Apple's clang (it's hardcoded inside of nvcc). Some other compiler is needed to use nvcc on macOS. The easiest way is to install clang-omp from brew package manger:
```bash
$ brew install clang-omp
```

3. Set CMAKE_MACOSX_RPATH to avoid cmake warnings; remove redundant ""-std=c++11"" option from CUDA_NVCC_FLAGS:
```bash
$ diff -wbur ./CMakeLists.txt.old ./CMakeLists.txt
--- ./CMakeLists.txt.old        2016-12-12 20:18:57.000000000 +0200
+++ ./CMakeLists.txt    2016-12-12 22:19:52.000000000 +0200
@@ -233,6 +233,7 @@
             set (dlib_needed_libraries ws2_32 winmm comctl32 gdi32 imm32)
          endif()
       elseif(APPLE) ############################################################################
+         set(CMAKE_MACOSX_RPATH 1)
          if (NOT DLIB_NO_GUI_SUPPORT)
             find_package(X11 QUIET)
             if (X11_FOUND)
@@ -509,7 +510,7 @@
             # Note that we add __STRICT_ANSI__ to avoid freaking out nvcc with gcc specific
             # magic in the standard C++ header files (since nvcc uses gcc headers on
             # linux).
-            list(APPEND CUDA_NVCC_FLAGS ""-arch=sm_30;-std=c++11;-D__STRICT_ANSI__;-D_MWAITXINTRIN_H_INCLUDED;-D_FORCE_INLINES"")
+            list(APPEND CUDA_NVCC_FLAGS ""-arch=sm_30;-D__STRICT_ANSI__;-D_MWAITXINTRIN_H_INCLUDED;-D_FORCE_INLINES"")
 
             include(cmake_utils/test_for_cudnn/find_cudnn.txt)
```

4. It looks like there is some problem inside of dlib cmake files. It's needed to define ""-std=c++11"" compiler option explicitly, CMAKE_CXX_STANDARD is not enough:
```bash
$ diff -wbur ./cmake_utils/use_cpp_11.cmake.old ./cmake_utils/use_cpp_11.cmake
--- ./cmake_utils/use_cpp_11.cmake.old  2016-12-12 22:22:05.000000000 +0200
+++ ./cmake_utils/use_cpp_11.cmake      2016-12-12 22:20:47.000000000 +0200
@@ -78,6 +78,10 @@
       # newer.
       if (NOT CMAKE_CXX_STANDARD OR CMAKE_CXX_STANDARD LESS 11)
          set(CMAKE_CXX_STANDARD 11)
+       set(CMAKE_CXX_STANDARD_REQUIRED YES)
+       if (""${CMAKE_CXX_COMPILER_ID}"" STREQUAL ""Clang"")
+           add_global_compiler_switch(""-std=c++11"")
+       endif()
          message(STATUS ""C++11 activated."")
       endif()
    endif()
```

5. And finally remove redundant -std=c++11 from CUDA_NVCC_FLAGS once again:
```bash
$ diff -wbur ./cmake_utils/test_for_cudnn/CMakeLists.txt.old ./cmake_utils/test_for_cudnn/CMakeLists.txt
--- ./cmake_utils/test_for_cudnn/CMakeLists.txt.old     2016-12-12 22:22:05.000000000 +0200
+++ ./cmake_utils/test_for_cudnn/CMakeLists.txt 2016-12-12 22:25:05.000000000 +0200
@@ -5,7 +5,7 @@

 find_package(CUDA 7.5 REQUIRED)
 set(CUDA_HOST_COMPILATION_CPP ON)
-list(APPEND CUDA_NVCC_FLAGS ""-arch=sm_30;-std=c++11;-D__STRICT_ANSI__"")
+list(APPEND CUDA_NVCC_FLAGS ""-arch=sm_30;-D__STRICT_ANSI__"")
 add_definitions(-DDLIB_USE_CUDA)
 
 include(find_cudnn.txt)
```

6. run cmake with correct clang and clang++ (installed with brew):
```bash
$ cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_COMPILER=clang-omp++ -DCMAKE_C_COMPILER=clang-omp ../
$ make
$ make install
```

7. Now Xcode is ready to build your programs with dlib (and Apple's clang).
",{},{}
1231,IssuesEvent,2017-03-04 12:12:20+00:00,16331291,davisking/dlib,6259399,davisking,,,closed,face recognition with my face detector,[],[],1,"as for face recogntion:
--------------------------------------------------------------
 std::vector<matrix<rgb_pixel>> faces;
    for (auto face : detector(img))
    {
        auto shape = sp(img, face);
        matrix<rgb_pixel> face_chip;
        extract_image_chip(img, get_face_chip_details(shape,150,0.25), face_chip);
