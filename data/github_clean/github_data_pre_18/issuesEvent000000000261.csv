16834,IssuesEvent,2018-07-16 07:44:05+00:00,124853261,tensorflow/hub,10295418,chiragjn,15658638,tensorflow,closed,Export cached tf-hub module as a part of another tf model for serving,[],[],2,"I am trying to combine [sentencepiece](https://github.com/google/sentencepiece/tree/master/tensorflow/tf_sentencepiece) and universal sentence encoder lite as a single model.

```python
import os
import tensorflow as tf
import tensorflow_hub as hub
import tf_sentencepiece as tfs
# import sentencepiece as spm

class SPUSE(object):
    """"""
    Needs the tf_sentencepiece op installed
    """"""

    def __init__(self, use_path):
        self.use = hub.Module(use_path)

        with tf.Session() as session:
            spm_path = session.run(self.use(signature=""spm_path""))

        model_proto = tf.gfile.GFile(spm_path, 'rb').read()

        # -- graph begin --
        self.text = tf.placeholder(tf.string, [None])
        self.input_placeholder = tfs.encode_sparse(
            self.text, model_proto=model_proto)
        self.input_placeholder = tf.cast(self.input_placeholder, tf.int64)
        self.encoded = self.use(
            inputs=dict(
                values=self.input_placeholder.values,
                indices=self.input_placeholder.indices,
                dense_shape=self.input_placeholder.dense_shape
            )
        )
        init_op = tf.group(
            [tf.global_variables_initializer(), tf.tables_initializer()])
        # -- graph end --
        self.session = tf.Session()
        self.session.run(init_op)

    def encode(self, sentences):
        encoded = self.session.run(self.encoded, feed_dict={
                                   self.text: sentences})
        return encoded

    def export(self, path, version):
        export_path = os.path.join(
            tf.compat.as_bytes(path),
            tf.compat.as_bytes(str(version)))
        print('Exporting trained model to', export_path)
        builder = tf.saved_model.builder.SavedModelBuilder(export_path)
        tensor_info_text = tf.saved_model.utils.build_tensor_info(self.text)
        tensor_info_encoded = tf.saved_model.utils.build_tensor_info(
            self.encoded)

        prediction_signature = (
            tf.saved_model.signature_def_utils.build_signature_def(
                inputs={'text': tensor_info_text},
                outputs={'encoded': tensor_info_encoded},
                method_name=tf.saved_model.signature_constants.PREDICT_METHOD_NAME
            )
        )

        legacy_init_op = tf.group(tf.global_variables_initializer(
        ), tf.tables_initializer(), name='legacy_init_op')
        builder.add_meta_graph_and_variables(
            self.session, [tf.saved_model.tag_constants.SERVING],
            signature_def_map={
                'encode': prediction_signature,
            },
            legacy_init_op=legacy_init_op
        )
        builder.save()
        print('Done exporting!')

if __name__ == '__main__':
    use_encoder = SPUSE(
        ""http://tfhub.dev/google/universal-sentence-encoder-lite/2"")
    print(use_encoder.encode(
        ['hello world.', 'I have a dog.', 'I have an apple.']))
    use_encoder.export('/tmp/export_test/', 1)
```

The export is successful but when I move this saved model from one machine to another machine, tf-serving tries to load from the cached path of the machine the model was exported from

```bash
tensorflow.python.framework.errors_impl.InvalidArgumentError: Unsuccessful TensorSliceReader constructor: Failed to get matching files on /var/folders/zh/5mjzfxvj6s96_b3hp_xjrlc40000gn/T/tfhub_modules/88bcbc18de736c0d220e01461d380fdaaf71603c/variables/variables: Not found: /var/folders/zh/5mjzfxvj6s96_b3hp_xjrlc40000gn/T/tfhub_modules/88bcbc18de736c0d220e01461d380fdaaf71603c/variables; No such file or directory
```

How do I export it explicitly as a part of my larger model in path agnostic way?",{},{}
