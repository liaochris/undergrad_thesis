  File ""/usr/local/lib/python2.7/site-packages/django_tastypie-0.9.11-py2.7.egg/tastypie/resources.py"", line 1165, in post_list
    updated_bundle = self.obj_create(bundle, request=request, **self.remove_api_resource_names(kwargs))

  File ""/usr/local/lib/python2.7/site-packages/django_tastypie-0.9.11-py2.7.egg/tastypie/resources.py"", line 1774, in obj_create
    bundle = self.full_hydrate(bundle)

  File ""/usr/local/lib/python2.7/site-packages/django_tastypie-0.9.11-py2.7.egg/tastypie/resources.py"", line 698, in full_hydrate
    value = field_object.hydrate(bundle)

  File ""/usr/local/lib/python2.7/site-packages/django_tastypie-0.9.11-py2.7.egg/tastypie/fields.py"", line 637, in hydrate
