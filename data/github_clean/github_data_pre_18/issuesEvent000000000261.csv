    std::string modelFileNameCString = [modelFileName UTF8String];
    
    detector = dlib::get_frontal_face_detector();
    dlib::deserialize(modelFileNameCString) >> sp;
    
    // FIXME: test this stuff for memory leaks (cpp object destruction)
    self.prepared = YES;
}`



