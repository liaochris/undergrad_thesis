9948,IssueCommentEvent,2015-08-20 03:23:45+00:00,27609645,web2py/pydal,10407290,stephenrauch,33118,web2py,101624301,132873904,"I was unable to duplicate this using only pydal (no web2py).  When trying to do validate_and_update_or_insert() I was receiving an error of:

```
AttributeError: 'Table' object has no attribute '_primarykey'
```

By adding ``_key='id'`` I was able to get the following to work (both prints returned 'dict'):

```python
db = DAL(DEFAULT_URI, check_reserved=['all'])
db.define_table('tt', Field('aa', 'json', default={}),)
db.tt.validate_and_update_or_insert(_key='id', id=1, aa={'a' : 1, 'b' : 0})
db.commit()
print(type(db.tt[1].aa))
db.tt.validate_and_update_or_insert(id==1, aa={'a' : 1, 'b' : 1})
db.commit()
print(type(db.tt[1].aa))
db.tt.drop()
db.close()
```",{},,User,False
