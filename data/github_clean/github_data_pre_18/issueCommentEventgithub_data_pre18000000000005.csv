```python
import time

ray.init(resources={""cpu"": 10, ""gpu"": 2})

@ray.remote(cpus=1)
def f(n):
  time.sleep(n)

time_buffer = 0.1

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(10)])
duration = time.time() - start_time
assert duration < 0.5 + time_buffer
assert duration > 0.5

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(11)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1

@ray.remote(cpus=3)
def f(n):
  time.sleep(n)

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(3)])
duration = time.time() - start_time
assert duration < 0.5 + time_buffer
assert duration > 0.5

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(4)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1

@ray.remote(gpus=1)
def f(n):
  time.sleep(n)

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(2)])
duration = time.time() - start_time
assert duration < 0.5 + time_buffer
assert duration > 0.5

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(3)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1

start_time = time.time()
ray.get([f.remote(0.5) for _ in range(4)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1
```

Multi resource tests
```python
import time

ray.init(resources={""cpu"": 10, ""gpu"": 10})

@ray.remote(cpus=1, gpus=9)
def f(n):
  time.sleep(n)

@ray.remote(cpus=9, gpus=1)
def g(n):
  time.sleep(n)

time_buffer = 0.1

start_time = time.time()
ray.get([f.remote(0.5), g.remote(0.5)])
duration = time.time() - start_time
assert duration < 0.5 + time_buffer
assert duration > 0.5

start_time = time.time()
ray.get([f.remote(0.5), f.remote(0.5)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1

start_time = time.time()
ray.get([g.remote(0.5), g.remote(0.5)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1

start_time = time.time()
ray.get([f.remote(0.5), f.remote(0.5), g.remote(0.5), g.remote(0.5)])
duration = time.time() - start_time
assert duration < 1 + time_buffer
assert duration > 1
```

multi local scheduler tests
```python
address_info = ray.worker._init(start_ray_local=True, num_local_schedulers=3, resources=[{""cpu"": 100, ""gpu"": 0}, {""cpu"": 5, ""gpu"": 5}, {""cpu"": 10, ""gpu"": 1}])

# This must be run on the first local scheduler
@ray.remote(num_cpu=11)
def run_on_1():
  return ray.worker.global_worker.plasma_client.store_socket == address_info[""object_store_addresses""][0].name

# This must be run on the second local scheduler.
@ray.remote(num_gpu=2)
def run_on_2():
  return ray.worker.global_worker.plasma_client.store_socket == address_info[""object_store_addresses""][0].name

# This must be run on the third local scheduler.
@ray.remote(num_cpu=6, num_gpu=1)
def run_on_3():
  return ray.worker.global_worker.plasma_client.store_socket == address_info[""object_store_addresses""][0].name

# This can be run anywhere.
@ray.remote(num_cpu=0, num_gpu=0)
def run_on_1_2_3():
  return ray.worker.global_worker.plasma_client.store_socket

# This must be run on the second or third local scheduler.
@ray.remote(num_gpu=1)
def run_on_2_3():
  return ray.worker.global_worker.plasma_client.store_socket

# This must be run on the first or third local scheduler.
@ray.remote(num_cpu=8)
def run_on_1_3():
  return ray.worker.global_worker.plasma_client.store_socket

results = []
for i in range(10000):
  index = np.random.randint(6)
  if index == 0:
    results.append((""run_on_1"", run_on_1.remote()))
  elif index == 1:
    results.append((""run_on_2"", run_on_2.remote()))
  elif index == 2:
    results.append((""run_on_3"", run_on_3.remote()))
  elif index == 3:
    results.append((""run_on_1_2_3"", run_on_1_2_3.remote()))
  elif index == 4:
    results.append((""run_on_2_3"", run_on_2_3.remote()))
  elif index == 5:
    results.append((""run_on_1_3"", run_on_1_3.remote()))

store_names = [object_store_address.name for object_store_address in address_info[""object_store_addresses""]]

for name, result in ray.get(results):
  if name == ""run_on_1"":
    assert result in [store_names[0]]
  elif name == ""run_on_2"":
    assert result in [store_names[1]]
  elif name == ""run_on_3"":
    assert result in [store_names[2]]
  elif name == ""run_on_1_2_3"":
    assert result in [store_names[0], store_names[1], store_names[2]]
  elif name == ""run_on_2_3"":
    assert result in [store_names[1], store_names[2]]
  elif name == ""run_on_1_3"":
    assert result in [store_names[0], store_names[2]]
  else:
    assert False
```

