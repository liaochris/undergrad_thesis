        ""default"": ""1""
      },
      ""rules"": [
        {
          ""metric_trigger"": {
            ""metric_name"": ""Percentage CPU"",
            ""metric_resource_uri"": ""/subscriptions/{subscriptionID}/resourceGroups/{resourceGroup}/providers/Microsoft.Compute/virtualMachineScaleSets/{VMSSName}"",
            ""time_grain"": ""PT1M"",
            ""statistic"": ""Average"",
            ""time_window"": ""PT5M"",
