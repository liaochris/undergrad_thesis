### My extended RegisterForm

```python
from flask_security.forms import LoginForm, RegisterForm, Required,\
    email_required, email_validator
from wtforms import BooleanField
from wtforms.fields.html5 import EmailField


class MasterRegisterForm(RegisterForm):
    """"""Extended reg form.""""""

    email = EmailField('E-mail', [email_required, email_validator])


    accept_tos = BooleanField('TOS',
                              [Required(message='Required')])

    _game_consent = '''I agree ...
    '''
    game_consent = BooleanField('game cons',
                                [Required(message='Required')])

    _marketing_consent = '''I agree ...
    '''
    marketing_consent = BooleanField(_marketing_consent,
                                     [Required(message='Required')])
```

When I replaced in `flask_security/forms.py` `email = StringField(..)` to ` to `email = EmailField(...)` everything seems to work fine.",{},,User,False
