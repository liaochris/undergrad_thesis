8076,IssueCommentEvent,2017-02-06 17:04:36+00:00,6235174,conda/conda,24482741,geoffreyphipps-uw,6392739,conda,161983530,277745480,"Yes, we still experience the bug. We put in a retry-loop as a workaround – so far the retry loop is working. Here:

export PATH=$1:$PATH
rc=17  # anything but zero.
tries=0
max_tries=3
while [[ $rc -ne 0 && $tries -lt $max_tries ]]; do
  source activate $2
  rc=$?
  tries=`expr $tries + 1`
  if [ $tries -gt 1 ] ; then
     # Use an ethernet-style increasing backoff
     jitter=`expr $RANDOM % 10 + 1`
     sleep `expr $jitter \* $tries`
     >&2 echo ""jobmon.env_submit_master: WARNING source activate failed, retrying, attempt: $tries""
  fi
done

if [ $tries -ge $max_tries ] ; then
  >&2 echo ""jobmon.env_submit_master: ERROR source activate failed""
  exit
fi

# get rid of the env name
shift 2
""$@""

Cheers
Geoff",{},,User,False
