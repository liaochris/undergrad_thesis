6539,IssuesEvent,2017-04-21 12:05:09+00:00,32769228,cockroachdb/cockroachdb-python,442,gpaul,6748139,cockroachdb,opened,escaped multi-line strings are being escaped again,[],[],0,"When I insert multiline strings it appears that they are being escaped again.

The following script, ran against cockroachdb beta-20170413 shows the issue:

```
import sqlalchemy as sa
from sqlalchemy.ext.declarative import declarative_base
import sqlalchemy.orm
from sqlalchemy_utils import create_database

_engine = sqlalchemy.create_engine('cockroachdb://root@127.0.0.1:26257/test', echo=False)
#_engine = sqlalchemy.create_engine('sqlite:///:memory:', echo=False)
_session_factory = sqlalchemy.orm.sessionmaker(bind=_engine)
dbsession = sqlalchemy.orm.scoped_session(_session_factory)

try:
    create_database(_engine.url)
except Exception:
    pass

Base = declarative_base()

class ConfigItem(Base):

    __tablename__ = 'configs'

    id = sa.Column(sa.Integer, primary_key=True)
    key = sa.Column(sa.Unicode, unique=True)
    value = sa.Column(sa.Unicode)

Base.metadata.create_all(_engine)

json_blob=""{\""foo\"": \""Bar\\nBaz\""}""

item=ConfigItem(key='cfg', value=json_blob)
dbsession.add(item)
dbsession.commit()

item = dbsession.query(ConfigItem).filter_by(key='cfg').one_or_none()
print(""retrieved value:"")
print(item.value)

print(""expected value:"")
print(json_blob)
```

Running this prints:
```
retrieved value:
{""foo"": ""Bar\\nBaz""}
expected value:
{""foo"": ""Bar\nBaz""}
```

Changing the connection string to use an in-memory sqlite db has the correct behaviour.",{},{}
