            if z == 1:
                loss, st = do_one_sentence(rnn, ""first"", None, sentence, params, vocab, pc, 'perplexity')
            else:
                loss, st = do_one_sentence(rnn, None, st, sentence, params, vocab, pc, 'perplexity') 
            # sum accumulated losses, and do forward-backward as usual.
            batch_loss = dy.esum(loss)/len(loss)
            print ""batch %d loss:"" % z, batch_loss.value() # call forward on batch
            print ""train perpl."", (dy.exp(batch_loss)).npvalue()
            #call backward pass
            batch_loss.backward()
            #print(batch_loss.gradient())

            trainer.update()

     def do_one_sentence(rnn, status, state, sentence, params, word2int, pc, loss_fn):
        if status is not None:
            s = rnn.initial_state()
        else:
            s = state

        R = dy.parameter(params[""R""])
        bias = dy.parameter(params[""bias""])
        lookup = params[""lookup""]
        sentence = [word2int[c] for c in sentence]
        loss = []
        for word,next_word in zip(sentence,sentence[1:]):
            s = s.add_input(lookup[word])
            preds = dy.log_softmax(R*(s.output()) + bias)
            loss.append( -(dy.pick(preds,next_word)))

        return loss, s
`

where the `do_one_sentence()` loss calculation function accepts as input a state to set as the first hidden state, unless this is the first input in the entire sequence of input sequences, in which case i use the `initial_state()` function.

