```python
from gcloud import bigtable
from oauth2client.service_account import ServiceAccountCredentials

from .exceptions import ConnectionError

scopes = ['https://www.googleapis.com/auth/sqlservice.admin']

__all__ = [
    'connect', 'get_db', 'get_connection'
]

_connection_settings = {}
_connections = {}
_dbs = {}


def register_connection(key, project_id, instance_id, admin=False, **kwargs):
    """"""Register db connection credentials
    Args:
        project_id (str): Google ID of the project
        instance_id (str): Google ID of the Bigtable instance
        admin (bool): If you need to run admin-level commands
            like to create tables/column families etc

    This function will store connection in a global dictionary of connections

    """"""
    global _connection_settings

    conn_settings = {
        'key': key,
        'project_id': project_id,
        'admin': admin
    }

    conn_settings.update(kwargs)
    _connection_settings[instance_id] = conn_settings


def disconnect(instance_id):
    """"""Disconnect the connection
    Args:
        instance_id (str): Google ID of the Bigtable instance
    """"""
    global _connections
    global _dbs

    if instance_id in _connections:
        # get_connection(instance_id=instance_id).close()
        del _connections[instance_id]
    if instance_id in _dbs:
        del _dbs[instance_id]


def get_connection(instance_id=None, reconnect=False):
    """"""
    Get connection from a dictionary of registered connections
    If no connection is registered for given instance_id
    the new connection will be established and registered

    Args:
        instance_id (str): Google ID of the Bigtable instance

    Returns:
        Bigtable instance of the connection


    """"""
    global _connections
    global _connection_settings

    # Delete if reconnect asked
    if reconnect:
        disconnect(instance_id)

    # If not instance_id is given and we have only a single
    # registered connection - return it
    if not instance_id:
        instances = _connections.keys()
        if len(instances) == 1:
            return _connections[instances.pop()]
        elif len(instances) > 1:
            raise AttributeError('Instance ID should be provided')
        else:
            raise ConnectionError('No connections registered yet')

    key = _connection_settings[instance_id].get('key')
    pid = _connection_settings[instance_id].get('project_id')
    admin = _connection_settings[instance_id].get('admin', False)

    # if not connection is registered,
    # create new connection
    if instance_id not in _connections:
        try:
            credentials = ServiceAccountCredentials.from_json_keyfile_name(
                key, scopes=scopes)
            client = bigtable.Client(
                project=pid, credentials=credentials, admin=admin)
            client.start()
            _connections[instance_id] = client.instance(instance_id)
            _dbs[instance_id] = client

        except Exception, e:
            raise ConnectionError(
                ""Cannot connect to bigtable %s :\n%s"" % (instance_id, e))
    return _connections[instance_id]


def get_db(instance_id, reconnect=False):
    global _dbs

    if reconnect:
        disconnect(instance_id)

    if instance_id not in _dbs:
        conn = get_connection(instance_id)
    return _dbs[instance_id]


def connect(key, project_id, instance_id, admin=False, **kwargs):
    """"""Primary function to call when we need to establish a new
    connection

    Args:
        project_id (str): Google ID of the project
        instance_id (str): Google ID of the Bigtable instance
        admin (bool): If you need to run admin-level commands
            like to create tables/column families etc

    Returns:
        Bigtable instance of the connection

    """"""
    global _connections

    if instance_id not in _connections:
        register_connection(
            key, project_id, instance_id, admin, **kwargs)

    # TODO: reconnect doesn't work, need debug
    # when you change admin=True->False with reconnect=True, no changes
    # reflected
    return get_connection(
        instance_id, kwargs.get('reconnect', False))
```

