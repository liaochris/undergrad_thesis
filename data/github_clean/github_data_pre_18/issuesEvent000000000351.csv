import autograd.numpy as np
from autograd import grad
from autograd import jacobian
from scipy import *
import time

def AutoGreek(S,r,K,T,v,delta):

        z = np.random.normal(0,1)
        return ((S*exp((r - delta - .5*(v**2))*T + (v * z*sqrt(T))) - K)* exp(-r*T))

abdul = grad(AutoGreek)

print abdul(100.0,.05,100.0,1.0,.2,.01)

I want to get the sensitivities with respect to S,r,T and v in the above function.",{},{}
