    :param resource_pool: ResourcePool to place the VirtualMachine in
    :param datastore: DataStrore to place the VirtualMachine on
    """"""
    global cpucount
    global memorysize
    global disksizes
    unit_number = 0
    disk_type = 'thin'

    datastore_path = '[' + str(datastore.name) + '] ' + vm_name 
    dbg('%s %s %s' % (datastore, datastore.name, datastore_path))
    devices = []

    scsi_spec = vim.vm.device.VirtualDeviceSpec()
    scsi_spec.operation = vim.vm.device.VirtualDeviceSpec.Operation.add
    scsi_spec.device = vim.vm.device.ParaVirtualSCSIController()
    scsi_spec.device.busNumber = 0
    scsi_spec.device.controllerKey = 100
    scsi_spec.device.sharedBus = 'noSharing'
    devices.append(scsi_spec)

    disk = 40
    new_disk_kb = int(disk) * 1024 * 1024
    disk_spec = vim.vm.device.VirtualDeviceSpec()
    disk_spec.operation = vim.vm.device.VirtualDeviceSpec.Operation.add
    disk_spec.fileOperation = vim.vm.device.VirtualDeviceSpec.FileOperation.create
    disk_spec.device = vim.vm.device.VirtualDisk()
    disk_spec.device.backing = vim.vm.device.VirtualDisk.FlatVer2BackingInfo()
    if disk_type == 'thin':
        disk_spec.device.backing.thinProvisioned = True
    disk_spec.device.backing.diskMode = 'persistent'
    disk_spec.device.backing.fileName = datastore_path + '/' + vm_name + '.vmdk'
    disk_spec.device.backing.datastore = datastore
    disk_spec.device.key = 2001
    disk_spec.device.unitNumber = 1
    disk_spec.device.capacityInKB = new_disk_kb
    disk_spec.device.controllerKey = 100
    devices.append(disk_spec)
    dbg(""Creating new disk with %sGBs"" % disk)

    dbg(""Creating new NIC for network '%s'"" % (network.name))
    #add a NIC. the network Name must be set as the device name to create the NIC.
    nic_spec = vim.vm.device.VirtualDeviceSpec()
    nic_spec.operation = vim.vm.device.VirtualDeviceSpec.Operation.add
    nic_spec.device = vim.vm.device.VirtualE1000()
    nic_spec.device.deviceInfo = vim.Description()
#    nic_spec.device.deviceInfo.label = 'Network adapter 1'
    nic_spec.device.deviceInfo.summary = network.name
    nic_spec.device.backing = vim.vm.device.VirtualEthernetCard.NetworkBackingInfo()
    nic_spec.device.backing.network = network 
    nic_spec.device.backing.deviceName = network.name
    nic_spec.device.connectable = vim.vm.device.VirtualDevice.ConnectInfo()
    nic_spec.device.connectable.startConnected = True
    nic_spec.device.connectable.connected = True
    nic_spec.device.connectable.allowGuestControl = True 
    devices.append(nic_spec)

    vmx_file = vim.vm.FileInfo(vmPathName=datastore_path)

#    vmx_file = vim.vm.FileInfo(logDirectory=datastore_path,
#                               snapshotDirectory=datastore_path,
#                               suspendDirectory=datastore_path,
#                               vmPathName=datastore_path)

 
    config = vim.vm.ConfigSpec(name=vm_name, memoryMB=long(memorysize), numCPUs=cpucount,
                               deviceChange=devices, files=vmx_file, guestId=guestosid,
                               version='vmx-08', annotation=annotation)

    print ""Creating VM {}..."".format(vm_name)
    dbg(devices)
    task = vm_folder.CreateVM_Task(config=config, pool=resource_pool, host=host)
#    tasks.wait_for_tasks(si, [task])
