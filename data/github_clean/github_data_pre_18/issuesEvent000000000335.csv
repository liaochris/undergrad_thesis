```python
# Warning: This script may cost about 100MB of memory.

import gc
import time

from multidict import CIMultiDict, istr


keys = [ 
    ""Set-Cookie"",
    ""Accept-Encoding"",
    ""Content-Length"",
    ""Content-Type"",
    ""Location"",
    ""User-Agent"",
]

for i in range(200000):
