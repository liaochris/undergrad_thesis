In [1]: from skimage.feature import BRIEF
In [2]: import numpy as np
In [3]: keypoints = np.random.randint(10, 502, size=(1000, 2))
In [4]: from skimage import data
In [5]: astro = data.astronaut()[:, :, 1]
In [6]: brief = BRIEF()
In [7]: %timeit brief.extract(astro, keypoints)
6.7 ms ± 24.6 µs per loop (mean ± std. dev. of 7 runs, 100 loops each)
```

