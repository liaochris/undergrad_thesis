3237,IssueCommentEvent,2017-08-07 13:58:10+00:00,8292338,ultrabug/py3status,56311,tobes,,,241179957,320670973,"I think we can do better with the thresholds.

the following diff allows us to use the thresholds more flexibly so we can have formats like

`\?color=1h {name} {price_usd}` 

the documentation would also need updating a little to reflect this.

```diff
diff --git a/py3status/modules/coin_market.py b/py3status/modules/coin_market.py
index 736599c..c7ffd12 100644
--- a/py3status/modules/coin_market.py
+++ b/py3status/modules/coin_market.py
@@ -7,7 +7,7 @@ Configuration parameters:
         Please limit requests to no more than 10 per minute. (default 600)
     format: display format for this module (default '{format_coin}')
     format_coin: display format for coins
-        (default '{name} ${price_usd:.2f} {percent_change_24h}')
+        (default '{name} ${price_usd:.2f} [\?color=24h {percent_change_24h}]')
     format_separator: show separator only if more than one (default ' ')
     markets: number of top ranked markets or list of user-inputted markets
         (default ['btc'])
@@ -74,7 +74,7 @@ losers
 class Py3status:
     cache_timeout = 600
     format = '{format_coin}'
-    format_coin = '{name} ${price_usd:.2f} {percent_change_24h}'
+    format_coin = '{name} ${price_usd:.2f} [\?color=24h {percent_change_24h}]'
     format_separator = ' '
     markets = ['btc']
     request_timeout = 5
@@ -177,11 +177,11 @@ class Py3status:
             temporary = {}
             for k, v in market.items():
                 if 'percent_change' in k and v:
-                    _fmt = '+%s%%' % v if float(v) > 0 else '%s%%' % v
-                    temporary[k] = self.py3.safe_format('\?color=%s %s' % (
-                        self.py3.threshold_get_color(v, k), _fmt))
-                else:
-                    temporary[k] = v
+                    # set the thresholds for this market
+                    # these will be colors 1h 24h and 7d
+                    threshold_name = k[15:]
+                    self.py3.threshold_get_color(v, threshold_name)
+                temporary[k] = v
 
             new_data.append(self.py3.safe_format(self.format_coin, temporary))
```",{},,User,False
