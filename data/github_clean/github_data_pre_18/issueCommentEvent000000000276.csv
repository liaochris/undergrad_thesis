```python
#!/usr/bin/env python

import asyncio
import logging
from scriptworker.exceptions import DownloadError
from scriptworker.utils import retry_async

logging.basicConfig()
log = logging.getLogger()
log.setLevel(logging.DEBUG)

count = [0]

async def foo():
    count[0] += 1
    log.info(count[0])
    if count[0] < 2:
        raise DownloadError(""foo"")
    log.info(""YAY"")
    return ""yay""


def callback(*args, **kwargs):
    return .1

loop = asyncio.get_event_loop()
loop.run_until_complete(
    retry_async(
        foo, retry_exceptions=(DownloadError, ),
        sleeptime_callback=callback
    )
)
```

By default `retry_exceptions` is `(Exception, )` which is overly broad, but it shouldn't break here. I can try making the exception list more restrictive and explicit.",{},MEMBER,User,False
