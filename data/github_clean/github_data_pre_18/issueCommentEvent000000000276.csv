           source=l.query)
resp = sql.send(query)

armyRose = [""#798234"",
            ""#a3ad62"",
            ""#d0d3a2"",
            ""#fdfbe4"",
            ""#f0c6c3"",
            ""#df91a3"",
            ""#d46780""]

# Make a figure and axes with dimensions as desired.
fig = plt.figure(figsize=(8, 3))
ax1 = fig.add_axes([0.05, 0.80, 0.9, 0.15])

cmap = mpl.cm.cool
norm = mpl.colors.Normalize(vmin=5, vmax=10)
cb1 = mpl.colorbar.ColorbarBase(ax1, cmap=cmap,
                                norm=norm,
                                orientation='horizontal')
cmap = mpl.colors.ListedColormap(armyRose) #['r', 'g', 'b', 'c'])
cmap.set_over('0.25')
cmap.set_under('0.75')
# length of bounds array must be one greater than length of color list
bounds = bin_edges # [1, 2, 4, 7, 8]
norm = mpl.colors.BoundaryNorm(bounds, cmap.N)
cb2 = mpl.colorbar.ColorbarBase(ax1, cmap=cmap,
                                norm=norm,
                                # to use 'extend', you must
                                # specify two extra boundaries:
                                boundaries=list(map(lambda x: round(x, 2), bounds)),
                                ticks=list(map(lambda x: round(x, 2), bounds)),
                                # ticks=list(map(lambda x: round(x, 2), bounds)),
                                spacing='proportional',
                                orientation='horizontal')
cb2.set_label('column name')
```

Which will produce 
![legend](https://user-images.githubusercontent.com/1041056/28828310-5e49e560-769e-11e7-9100-78ea394d02a7.png)
",{},,User,False
