12325,IssueCommentEvent,2017-09-21 03:12:02+00:00,82310639,ni/nidaqmx-python,6227348,ardeal,5598284,ni,259008518,331038858,"```

with nidaqmx.Task() as task:
    mwchan = task.ai_channels.add_ai_voltage_chan(""Dev1/ai0"")
    task.timing.cfg_samp_clk_timing(fs)
    # print mwchan.physical_channel.ai_term_cfgs

    while True:
        tdata = task.read(number_of_samples_per_channel=nfft)
        # data_all_list.append(tdata)
        # testdata = daq.read_usb6009(fs, nfft)
        testdata = np.array(tdata)
        testdata -= np.mean(testdata)

        ffto = np.fft.fft(testdata) / nfft
        ffto = np.abs(ffto)
        ffto = ffto[0:(nfft / 2 + 1)]
        ffto[0] = 0
        bf = bis.bispectrum(testdata, nfft)
        fdata = bf[0:(nfft / 2 + 1)]
        fdata[0] = 0


```",{},NONE,User,False
