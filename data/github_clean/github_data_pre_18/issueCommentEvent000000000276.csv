13449,IssueCommentEvent,2017-11-29 15:32:06+00:00,13258039,aio-libs/aiohttp,4001789,thehesiod,7049303,aio-libs,277599554,347896715,"here's what I'm doing: 
```python
from aiohttp.test_utils import make_mocked_request
from aiohttp.multipart import MultipartWriter
from aiohttp.http_parser import HttpRequestParser
from aiohttp import web

class AiohttpRawRequestWrapper(wrapt.ObjectProxy):
    @property
    def _method(self):
        return self.method

    @property
    def rel_url(self):
        assert not self.url.scheme
        return self.url

    async def gmail_batch(self, req: web.Request):
        reader = await req.multipart()
        writer = MultipartWriter()

        async for part in reader:
            async for data in part:
                parser = HttpRequestParser(self, asyncio.get_event_loop())
                messages, upgraded, data = parser.feed_data(data)
                assert len(messages) == 1
                assert len(messages[0]) == 2
                assert messages[0][1].is_eof()

                # see https://github.com/aio-libs/aiohttp/issues/2568
                parsed_req = AiohttpRawRequestWrapper(messages[0][0])
                match_info = await self.resolve_req(parsed_req)
                # endpoint = self.endpoints.get((parsed_req.method, parsed_req.url.path))

                if match_info is None:
                    assert False

                transport = MockAioHttpTransport()
                protocol = mock.Mock()
                protocol._drain_helper = mock.CoroutineMock()
                loop = asyncio.get_event_loop()
                stream = StreamWriter(protocol, transport, loop)
                payload_writer = PayloadWriter(stream, loop)
                req = make_mocked_request(parsed_req.method, parsed_req.url, parsed_req.headers, payload=payload.BytesPayload(data), writer=payload_writer, payload_writer=payload_writer)
                req._match_info = match_info
                resp = await match_info.handler(req)

                await resp.prepare(req)
                await resp.write_eof()

                writer.append(transport.buf, part.headers)

        return web.Response(body=writer, headers=writer.headers)
```

to support: https://developers.google.com/google-apps/calendar/batch",{},CONTRIBUTOR,User,False
