6536,IssueCommentEvent,2018-02-13 03:13:04+00:00,66290615,sabricot/django-elasticsearch-dsl,289531,stevelacey,,,290915198,365137999,"I stumbled across your post, and whilst this isn't quite what you're asking for, this is how I went about doing full search tests:

**indices.py**

```py
from django.conf import settings
from django_elasticsearch_dsl import Index as DDSLIndex


class Index(DDSLIndex):
    def __init__(self, name, **kwargs):
        if settings.TESTING:
            name = 'test_' + name
        super(Index, self).__init__(name, **kwargs)


asset = Index('assets')
```

**mixins.py**

```py
from django_elasticsearch_dsl.registries import registry


class SearchTestMixin(object):
    """"""Search test mixin recreates the Elasticsearch indices every test""""""
    def setup_method(self):
        for index in registry.get_indices():
            if index.exists():
                index.delete()
            index.create()

    def teardown_method(self):
        for index in registry.get_indices():
            index.delete()
```",{},NONE,User,False
