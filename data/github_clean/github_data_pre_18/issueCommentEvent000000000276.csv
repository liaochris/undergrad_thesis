14229,IssueCommentEvent,2018-08-29 04:27:59+00:00,23953531,androguard/androguard,6715194,ksg97031,8758456,androguard,354652548,416820283,"If you just want to get frequency about all method call, i think it's better.
```python
import time
from androguard.misc import AnalyzeAPK

def frequency(dx, target, api_freq):
    for c in dx.get_classes():
        for key, items in c.xrefto.items():
            for item in items:
                kind, method, offset = item
                if method in api_freq:
                    api_freq[method] += 1
                else:
                    api_freq[method] = 1

def main():
    tic = time.time()
    a, d, dx = AnalyzeAPK('G:\\apk\\test.apk')
    dx.create_xref()

    API_freq = dict()
    frequency(dx, target, API_freq)

    print(sorted(API_freq.items(), key=lambda b:b[1]))
    print(time.time()-tic)

if __name__ == '__main__':
    main()
```",{},CONTRIBUTOR,User,False
