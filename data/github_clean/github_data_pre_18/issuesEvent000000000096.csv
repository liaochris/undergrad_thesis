        [True, True, True],
        [False, False, False],
        [True, True, True]
    ])

    data = skimage.img_as_uint(data)
    skimage.io.imsave(path, data)

    assert True
```


*Expected*: Running the code manually (e.g. via ```test_binary_mask_save("""")```) and via pytest should create a striped image.

