Current thread 0xb7514940 (most recent call first):
  File ""/home/serhiy/.local/lib/python3.7/site-packages/simplejson/decoder.py"", line 404 in raw_decode
  File ""/home/serhiy/.local/lib/python3.7/site-packages/simplejson/decoder.py"", line 374 in decode
  File ""/home/serhiy/.local/lib/python3.7/site-packages/simplejson/__init__.py"", line 533 in loads
