6899,IssuesEvent,2018-03-19 18:22:31+00:00,34864402,apache/incubator-mxnet,11234557,cjolivier01,47359,apache,closed,Different convolution result between MXNet and Tensorflow?,"[{'id': 786012490, 'url': 'https://api.github.com/repos/apache/incubator-mxnet/labels/Need%20Triage', 'name': 'Need Triage', 'color': 'd93f0b', 'default': False}]",[],8,"I am trying to convert a CNN model trained by tensorflow to MXNet(since tensorflow's huge GPU memory cost and low speed, I want to deploy my model in MXNet), but I found different result when I use same variables. here is my test code:(tensorflow data format(NHWC), MXNet data format(NCHW)
```
import tensorflow as tf
import mxnet as mx
import glog as logging
import numpy as np
from collections import namedtuple
import tensorflow.contrib.slim as slim
Batch = namedtuple('Batch', ['data'])
img1 = np.random.rand(1,32,32,3)#for tensorflow NHWC format
img2 = img1.transpose((0,3,1,2))#for MXNet NCHW format
weights_dict={}
with tf.Graph().as_default():
    image = tf.placeholder(tf.float32, shape=[None, 32, 32, 3], name='images')
    out = slim.conv2d(image, 16, [3, 3], stride=1, padding='SAME', scope='cnn_conv0')
    params_cnn = tf.trainable_variables()
    for p in params_cnn:
        logging.info(p.name)
    init = tf.global_variables_initializer()
    with tf.Session() as sess:
        sess.run(init)
        for p in params_cnn:
            logging.info(p.name)
            logging.info(p.eval().shape)
            weights_dict[p.name] = p.eval()
        feed_d={image:img1}
        [np_result] = sess.run([out],feed_d)
        logging.info('tf cnn feature shape')
        logging.info(np_result.shape)

net = mx.sym.Variable(name=""data"")
net = mx.symbol.Convolution(name='cnn_conv0',data=net, kernel=(3, 3), stride=(1, 1), num_filter=16,pad=(1,1))
net = mx.sym.Activation(data=net, act_type=""relu"")
mod = mx.mod.Module(symbol=net,
                    context=mx.cpu(),
                    data_names=['data'],
                    label_names=None)
mod.bind(for_training=False, data_shapes=[('data', (1,3,32,32))],
         label_shapes=mod._label_shapes)
mod.init_params()
arg_params, aux_params= mod.get_params()
keys = arg_params.keys()
for k in keys:
    print k
    print arg_params[k].shape
    # print arg_params[k].asnumpy()
arg_params['cnn_conv0_weight']=mx.nd.array(weights_dict['cnn_conv0/weights:0'].transpose(3,2,0,1))#tranpose from tensorflow variable to MXNet ?
print '####mxnet params'
print arg_params['cnn_conv0_weight'].asnumpy().shape
mod.set_params(arg_params, aux_params, allow_missing=True)
mod.forward(Batch([mx.nd.array(img2)]))
cnn_feature = mod.get_outputs()[0].asnumpy()
cnn_feature = np.transpose(cnn_feature,(0,2,3,1))
print '#########'
logging.info('cnn_feature')
print cnn_feature.shape
if np.array_equal(cnn_feature, np_result):
    print 'PASS'
else:
    print 'ERROR'
```

The result is ERROR.Any advise will be appreciated. 
