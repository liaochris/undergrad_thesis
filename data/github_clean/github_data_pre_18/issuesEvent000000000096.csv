    """"""CharFiled with choices""""""
    subject = models.CharField(max_length=50)
    title = models.CharField(max_length=50)

    created_at = models.DateTimeField(auto_now_add=True, help_text=""Timestamp when the object was created"")
    updated_at = models.DateTimeField(auto_now=True, help_text=""Timestamp when the object was modified"")

    estimated_duration = models.DurationField()


class StaticStudyPlanTemplateModel(StudyPlanTemplateModel):
    """"""
    Proxy model for static study plan, which inherit from StudyPlanTemplateModel
    """"""
    class Meta:
        proxy = True

class DynamicStudyPlanTemplateModel(StudyPlanTemplateModel):
    """"""
