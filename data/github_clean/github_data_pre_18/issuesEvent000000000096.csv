                    ""responses"": {                                                                                                                                                             
                        ""200"": {                                                                                                                                                               
                            ""description"": ""Get a pet"",                                                                                                                                        
                            ""schema"": {                                                                                                                                                        
                                ""properties"": {                                                                                                                                                
                                    ""id"": {                                                                                                                                                    
                                        ""type"": ""integer"",                                                                                                                                     
                                    }                                                                                                                                                          
                                }                                                                                                                                                              
                            }                                                                                                                                                                  
                        }                                                                                                                                                                      
                    }                                                                                                                                                                          
                }                                                                                                                                                                              
            }                                                                                                                                                                                  
        }       
```

But I got

