650,IssueCommentEvent,2016-05-17 18:31:02+00:00,15367540,jruizgit/rules,12580387,enriched,,,153539015,219810733,"I worked on making a simple case with it, and am testing using the following:
```
var d = require('durable');
var uuid = require('node-uuid');


var sidCount = 400;
var counters = new Array(400).fill(0);
var side = Math.ceil(Math.sqrt(sidCount));
function printCounters() {
  for(var i = 0; i < side; i++) {
    var start = i * side;
    process.stdout.write('|' + counters.slice(start, start + side -1).join(' ') + '|\n');
  }
}

with(d.flowchart('test')) {
  with(stage('start')) {
    to('action').whenAll(m.command.eq('start'));
  }

  with(stage('action')) {
    run(function(c) {
      counters[c.s.sid]++;
      console.log('Fired action for sid[' + c.s.sid + ']');
      printCounters();
      c.post({id: uuid.v4(), sid: c.s.sid, command: 'await'});
    });
    to('await').whenAll(m.command.eq('await'));
  }

  with(stage('await')) {
    run(function(c) {
      c.startTimer('timeout', 1, uuid.v4());
    });
    to('action').whenAll(timeout('timeout'));
  }

  whenStart(function (host) {
    for(var i = 0; i < sidCount; i++) {
      host.post('test', {id: uuid.v4(), sid: i, command: 'start'});
    }
  })
}

d.runAll();
```",{},,User,False
