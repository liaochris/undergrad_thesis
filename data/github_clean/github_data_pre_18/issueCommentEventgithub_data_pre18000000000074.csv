1415,IssueCommentEvent,2016-02-08 23:31:45+00:00,1938370,Mottie/tablesorter,136959,Mottie,,,132020293,181622125,"Ok, try [this demo](http://jsfiddle.net/Mottie/4ac5kr3o/19/):

```js
$(function() {

  $(""table"").tablesorter({
    theme: ""blue"",
    sortList: [[0,0]],
    widgets: [""group"", ""columns"", ""filter"", ""zebra""],
    widgetOptions: {
      group_callback: function($cell, $rows, column, table) {
        // callback allowing modification of the group header labels
        // $cell = current table cell (containing group header cells
        //   "".group-name"" & "".group-count""
        // $rows = all of the table rows for the current group; table = current table (DOM)
        // column = current column being sorted/grouped
        var subtotal = 0;
        $rows.each(function() {
          var txt = $(this).find(""td"").eq(1).text().replace(/[$,]/g, '');
          subtotal += parseFloat(txt);
        });
        $cell.find("".group-count"").append(""; subtotal: $"" + subtotal);
      }
    }
  });

});
```

