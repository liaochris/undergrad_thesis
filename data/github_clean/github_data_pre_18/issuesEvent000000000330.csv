4366,IssuesEvent,2016-04-18 14:10:35+00:00,4978045,Parsely/pykafka,1536838,gossel-j,779641,Parsely,opened,Using BalancedConsumer with consumer_timeout_ms options do not receive message,[],[],0,"When I use BalancedConsumer with option consumer_timeout_ms, when I try to connect another BalancedConsumer it stops receive message and then timeout.

So basically after a rebalancing, the consumer never give new message and then timeout, only appear with the option consumer_timeout_ms.

```python
#!/usr/bin/env python

from argparse import ArgumentParser
import json
import logging
from pykafka import KafkaClient


def consume(args):
    client = KafkaClient(
        hosts=args.broker,
        zookeeper_hosts=args.zookeeper,
    )
    topic = client.topics[args.topic]
    consumer = topic.get_balanced_consumer(
        args.group,
        managed=False,
        auto_commit_enable=True,
        auto_start=True,
        consumer_timeout_ms=60000, # if this line is commented it works great
    )

    for msg in consumer:
        if msg is None:
            break
        logging.info(""partiton=%s offset=%s value=%s"" % (msg.partition.id, msg.offset, msg.value))


def main():
    logging.basicConfig(level=logging.INFO)
    parser = ArgumentParser(description='Produce dummy messages to kafka')
    parser.add_argument(
        '--broker', '-b',
        dest='broker',
        default='127.0.0.1:9092',
        type=str,
        metavar='kafka_broker_address(es)',
    )
    parser.add_argument(
        '--zookeeper', '-z',
        dest='zookeeper',
        default='127.0.0.1:2181',
        type=str,
        metavar='zookeeper_address(es)',
    )
    parser.add_argument(
        '--topic', '-t',
        dest='topic',
        default='dummy',
        type=str,
        metavar='topic_name',
    )
    parser.add_argument(
        '--group', '-g',
        dest='group',
        type=str,
        metavar='group_name',
        required=True,
    )

    args = parser.parse_args()

    consume(args)


if __name__ == '__main__':
    main()
```


**PyKafka version**: 2.3.1
**Kafka version**: 8.2.2
",{},{}
