3490,IssueCommentEvent,2018-01-07 16:57:14+00:00,80053206,joanvila/aioredlock,180812,akhilman,,,285893492,355836202,"Ok this is my acceptance test try. In this test first instance still have resource key occupied by previous lock while second instance already clean but just before second attempt resource key on first instance becomes free which simulates delay in cluster synchronization. And yes it fails to acquire lock.
```python
import asyncio
import os
import uuid

import aioredis
import asynctest
import pytest

from aioredlock import Aioredlock


@pytest.fixture
def redis_two_connections():
    return [
        {'host': 'localhost', 'port': 6379},
        {'host': 'localhost', 'port': 6378}
    ]


@pytest.fixture
async def redis_instances(redis_two_connections):

    instances = []

    for addr in redis_two_connections:
        redis = await aioredis.create_redis((addr['host'], addr['port']))
        instances.append(redis)

    yield instances

    for redis in instances:
        redis.close()
        await redis.wait_closed()


class TestAioredlock:

    reason = 'CI only has one redis instance'

    @pytest.mark.asyncio
    @pytest.mark.skipif(os.getenv('CI'), reason=reason)
    async def test_partial_lock_two_instances(
        self,
        redis_two_connections,
        redis_instances
    ):

        lock_manager = Aioredlock(redis_two_connections)
        resource = str(uuid.uuid4())
        garbage_value = 'garbage'

        # write garbage to resource key in first instance
        # print(redis_instances[0])
        await redis_instances[0].set(resource, garbage_value)

        # this patched sleep function will remove garbage from
        # frist instance before second try
        async def fake_sleep(delay):
            # remove garbage on sleep
            value = await redis_instances[0].get(resource)
            value = value.decode() if value else None
            if value == garbage_value:
                await redis_instances[0].delete(resource)

            # print('fake_sleep(%s), value %s' % (delay, value))
            await asyncio.sleep(delay)

        # here we will try to lock while first redis instance still have
        # resource key occupied by garbage
        # but just before second attemt patched asyncio.sleep() function
        # will clean up garbage key to let lock be acquired
        with asynctest.patch(""asyncio.sleep"", fake_sleep):
            lock = await lock_manager.lock(resource)
        assert lock.valid is True

        await lock_manager.unlock(lock)
        assert lock.valid is False

        await lock_manager.destroy()
```

