9775,IssueCommentEvent,2018-07-03 10:28:29+00:00,1199632,schematics/schematics,4018545,festinuz,7866441,schematics,227984559,402098371,"I've encountered a similar problem, here is how i managed to get around it
```python
class BaseModelOptions(SchemaOptions):
    def __init__(self, mappings=None, **kwargs):
        super().__init__(**kwargs)
        self.mappings = mappings or dict()


class BaseModelMeta(ModelMeta):
    def __new__(meta, name, bases, dct):
        dct.setdefault(""__optionsclass__"", BaseModelOptions)
        return super().__new__(meta, name, bases, dct)


class BaseModel(Model, metaclass=BaseModelMeta):
    pass
```",{},NONE,User,False
