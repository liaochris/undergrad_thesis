38,IssueCommentEvent,2017-01-15 18:44:54+00:00,68802946,h2non/pook,527325,mindflayer,,,195326649,272714693,"`import pook
import requests
from pook.engine import MockEngine
from pook.interceptors.base import BaseInterceptor

from tests import urlparse, urlencode
from mocket.mocket import Mocket
from mocket.mockhttp import Entry


class MocketInterceptor(BaseInterceptor):
    def activate(self):
        Mocket.enable()

    def disable(self):
        Mocket.disable()


class MocketEngine(MockEngine):

    @staticmethod
    def set_query_parameter(url, key, value):
        """"""Given a URL, set or replace a query parameter and return the
        modified URL.

        >>> MocketEngine.set_query_parameter('http://example.com?foo=bar&biz=baz', 'foo', 'stuff')
        'http://example.com?foo=stuff&biz=baz'

        """"""
        scheme, netloc, path, query_string, fragment = urlparse.urlsplit(url)
        query_params = urlparse.parse_qs(query_string)

        query_params[key] = value
        new_query_string = urlencode(query_params, doseq=True)

        return urlparse.urlunsplit((scheme, netloc, path, new_query_string, fragment))

    def __init__(self, engine):
        # Store pook engine
        self.engine = engine
        # Store HTTP client interceptors
        self.interceptors = []
        # Self-register MocketInterceptor
        self.add_interceptor(MocketInterceptor)

    def activate(self):
        for mock in self.engine.mocks:
            response = mock._response

            method, url = [str(m) for m in mock.matchers]
            # query = request._query
            body = response._body
            status = response._status
            headers = response._headers

            # for k, v in query.items():
            #     MocketEngine.set_query_parameter(url, k, v)

            Entry.single_register(method, url, body, status, headers)

        super(MocketEngine, self).activate()


@pook.activate
def test_my_api():
    pook.set_mock_engine(MocketEngine)
    mock = pook.get('http://twitter.com/api/1/foobar', reply=404, response_json={'error': 'foo'})

    resp = requests.get('http://twitter.com/api/1/foobar')
    assert resp.status_code == 404
    assert resp.json() == {'error': 'foo'}
    assert mock.calls == 1
`",{},,User,False
42,IssueCommentEvent,2016-02-09 14:15:39+00:00,46566669,jaraco/irc,14362102,Hornwitser,,,132205877,181881618,"Properly implemented, and in line with best practices, a client re-connecting to a resource online should exponentially increase it's retry timer every time it fails *ad infinitum*.  (An interesting read for what happens when you don't do this is the [Router Flood of University of Wisconsin NTP Server](http://pages.cs.wisc.edu/~plonka/netgear-sntp/).)  At a small scale, just waiting a minute works fine though.

What is _not_ fine is exponentially increasing the number of times the client tries to reconnect every minute, so that after less than 10 minutes it's doing a continuous flood of connection attempts against the IRC server.",{},,User,False
