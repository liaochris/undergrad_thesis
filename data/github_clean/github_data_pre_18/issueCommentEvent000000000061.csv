791,IssueCommentEvent,2017-04-13 07:58:56+00:00,30492678,facetoe/zenpy,1366896,facetoe,,,219484114,293820195,"Hi @sovietnorm, I've added support for identities. I'll need to update the docs but for now you can use the new functionality as follows:

```python
# Show identities for a user
for identity in zenpy_client.users.identities(id=21207616708):
    print(identity.id, identity.value, identity.verified, identity.primary)

# Create a new identity for a user
identity = zenpy_client.users.identities.create(
    user=21207616708,
    identity=Identity(type='email', value='example4@example.com')
)

# Update an identity
identity = zenpy_client.users.identities.update(
    user=21207616708,
    identity=Identity(id=identity.id, value='foo@barbaz.com')
)

user_id_or_object = 21207616708
identity_id_or_object = 6765149327

# Send email requesting verification
response = zenpy_client.users.identities.request_verification(
    user=user_id_or_object,
    identity=identity_id_or_object
)
print(""request verification response: {}"".format(response))

# Verify an identity
identity = zenpy_client.users.identities.verify(
    user=user_id_or_object,
    identity=identity_id_or_object
)
print(""verified: {}"".format(identity.verified))

# Make an identity the users primary identity
user_identities = zenpy_client.users.identities.make_primary(
    user=user_id_or_object,
    identity=identity_id_or_object
)
for identity in user_identities:
    print(identity.to_dict())

# Show a particular identity for a user
identity = zenpy_client.users.identities.show(
    user=user_id_or_object,
    identity=identity_id_or_object
)
print(identity)

# Delete an identity for a user
response = zenpy_client.users.identities.delete(
    user=user_id_or_object,
    identity=identity_id_or_object
)
print(""Delete response: {}"".format(response))
```",{},,User,False
