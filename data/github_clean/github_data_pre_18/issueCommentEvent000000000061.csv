11870,IssueCommentEvent,2015-09-14 07:55:20+00:00,6704888,django-import-export/django-import-export,1585431,int-ua,12345453,django-import-export,104200899,139989178,"I've written it this way:

    class ForeignKeyWidgetWithCreation(ForeignKeyWidget):
        def __init__(
                self,
                model,
                field='pk',
                create=False,
                *args, **kwargs):
            self.model = model
            self.field = field
            self.create = create
            # super(ForeignKeyWidgetWithCreation, self).__init__(*args, **kwargs)

        def clean(self, value):
            val = super(ForeignKeyWidgetWithCreation, self).clean(value)
            if self.create:
                instance, new = self.model.objects.get_or_create(**{
                    self.field: val
                })
                val = getattr(instance, self.field)
            return self.model.objects.get(**{self.field: val}) if val else None

# Usage example
    class PersonInvolvementResource(Resource):
        field1 = fields.Field(
            attribute='field1',
            widget=ForeignKeyWidgetWithCreation(
                OtherModel,
                field='name',
                create=True))",{},,User,False
