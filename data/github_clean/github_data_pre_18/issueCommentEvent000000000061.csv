9551,IssueCommentEvent,2016-04-28 15:31:05+00:00,15670215,nephila/djangocms-blog,754333,sephii,630341,nephila,138325657,215467961,"I found a workaround that avoids patching DjangoCMS itself but I'm really not sure it's clean (`djangocms_blog/cms_wizards.py`):

```python
registered_wizards = set()
for config in BlogConfig.objects.all().order_by('namespace'):
    new_wizard = type(str(slugify(config.app_title)), (PostWizard,), {})
    new_form = type(str('{0}Form').format(slugify(config.app_title)), (PostWizardForm,), {
        'default_appconfig': config.pk
    })
    post_wizard = new_wizard(
        title=_('New {0}').format(config.object_name),
        weight=200,
        form=new_form,
        model=Post,
        description=_('Create a new {0} in {1}').format(config.object_name, config.app_title),
    )

    if post_wizard.id not in registered_wizards:
        try:
            registered_wizards.add(post_wizard.id)
            wizard_pool.register(post_wizard)
        except AlreadyRegisteredException:  # pragma: no cover
            if settings.DEBUG:
                raise  
```",{},,User,False
