5843,IssueCommentEvent,2018-07-09 10:52:11+00:00,38095954,eternnoir/pyTelegramBotAPI,29206228,M1LKYWVY,,,339335431,403439311,"If somebode is interested in this issue, problem was solved in 1 hours with strange method.

```python
    url = 'https://api.telegram.org/bot{0}/getUpdates'.format(bot_token)
    result = requests.post(url)
    try:
        offset = json.loads(result.text)['result'][0]['update_id']
    except IndexError:
        offset = -1
    while True:
        url = 'https://api.telegram.org/bot{0}/getUpdates'.format(bot_token)
        result = requests.post(url, params={'offset': offset})
        json_string = json.loads(result.text)['result']
        for update in json_string:
            if 'new_chat_members' in update['message']:
                members = update['message']['new_chat_members']
                for member in members:
                    bot.send_message(update['message']['chat']['id'], service.get_text(14).format(member['first_name'], bot_name))
            data = telebot.types.Update.de_json(json.dumps(update))
            bot.process_new_updates([data])
            offset = int(json.loads(result.text)['result'][0]['update_id']) + 1
        sleep(0.5)
```",{},NONE,User,False
