```
class ProductViewSet(viewsets.ModelViewSet):
    serializer_class = ProductSerializer
    # other stuff

    def _did_qa(self, prev_instance, serializer):
        prev_status = prev_instance.status
        new_status = serializer.validated_data.get(""status"", None)

        if new_status == ACTIVE:

            if prev_status == QA:
                return True

        return False

    def perform_create(self, serializer):
        with reversion.create_revision():
            super().perform_create(serializer)
            reversion.set_user(self.request.user)
            reversion.set_comment(""Created"")

    def perform_update(self, serializer):
        prev_instance = copy(serializer.instance)

        with reversion.create_revision():
            super().perform_update(serializer)
            reversion.set_user(self.request.user)

            if self._did_qa(prev_instance, serializer):
                reversion_comment = ""QA Completed""
            else:
                reversion_comment = ""Modified""

            reversion.set_comment(reversion_comment)
    
    def perform_destroy(self, instance):
        LOG.info(""Before revision"")
        with reversion.create_revision():
            LOG.info(""Inside create revision"")
            super().perform_destroy(instance)
            reversion.set_user(self.request.user)
            reversion.set_comment(""Deleted"")
```",{},{}
