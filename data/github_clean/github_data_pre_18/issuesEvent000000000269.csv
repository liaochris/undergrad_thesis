-        warnings.warn(""I/O error({0}): {1}"".format(e.errno, e.strerror))
         return None


@@ -59,6 +59,14 @@
                 self.zones.update(links)
         else:
             self.zones = dict()
+            if os.path.isdir(_SYSTEM_ZONEINFO_DIR):
