    - pip install 'aggdraw==1.3.1' pillow
    - python -c ""from PIL import Image;import aggdraw; main = Image.new('RGB', (480, 1024), 'white'); d = aggdraw.Draw(main); p = aggdraw.Pen((90,) * 3, 0.5)""
