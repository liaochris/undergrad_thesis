The private key used to sign is 0x5e95384d8050109aab08c1922d3c230739bc16976553c317e5d0b87b59371f2a and does not change between samples.

I am using Populus 1.11.x testrpc for the EVM bit.

Here is the full log of 343 failed hashes (to detect a pattern): https://gist.github.com/miohtama/93b87a963dcc7c944b5d5e6142815347

Below is my test case

```
def test_order_signature(web3, exchange, parties_ready_to_trade, bought_token, sold_token, fee_recipient, private_key_hex, private_key_account):
    """"""Python and Solidity agree how to sign orders.""""""

    buyer, seller = parties_ready_to_trade

    failure_count = 0
    for i in range(0, 25600):
        to_buy = 300
        to_sell = 200
        maker_fee = random.randint(0, 100)
        taker_fee = random.randint(0, 100)

        fee_recipient = ""0x0000000000000000000000000000000000000000""

        o = create_test_order(
            web3,
            exchange_address=exchange.address,
            fee_recipient=fee_recipient,
            maker_address=seller,
            taker_address=buyer,
            maker_token=sold_token.address,
            taker_token=bought_token.address,
            maker_token_amount=to_sell,
            taker_token_amount=to_buy,
            maker_fee=maker_fee,
            taker_fee=taker_fee,
        )

        # Solidity takes our signature as granted
        hash = o.calculate_hash()
        hash_bytes = decode_hex(hash)

        data = o.sign_private_key(private_key_hex)

# is same as
#        hash = self.calculate_hash()
#        hash_bytes = decode_hex(hash)
#
  #      a = Account()
 #       sign_data = a.sign(hash_bytes, private_key=decode_hex(private_key_hex))
   #     signature_params = {
     #       ""hash"": hash,
      #      ""hash_bytes"": hash_bytes,
       #     ""v"": sign_data[""v""],
        #    ""r"": sign_data[""r""],
         #   ""s"": sign_data[""s""],
        #}
        #return signature_params


        try:
            assert exchange.call().isValidSignature(seller, hash_bytes,
                                                data[""v""],
                                                data[""r""],
                                                data[""s""],)
        except:
            print(""Failed signature is, number:"", i, ""data:"", data)
            failure_count += 1

    print(""Failure count is"", failure_count)
```

How Exchange.sol validates the signed message: https://github.com/0xProject/contracts/blob/master/contracts/Exchange.sol#L454

