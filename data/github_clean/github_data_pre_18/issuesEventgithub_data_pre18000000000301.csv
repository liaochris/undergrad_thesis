access_token = '...'
creative_ids = ['6037743397003', '6037743375803', '6037743378803']

CREATIVE_FIELDS = [
    'id',
    'object_url',
    'url_tags',
    'object_story_spec',
    'run_status',
]


def get_creatives_one_by_one():
    FacebookAdsApi.init(app_id, app_secret, access_token)
    creatives = []
    for creative_id in creative_ids:
        c = AdCreative(creative_id)
        creatives.append(c.remote_read(fields=CREATIVE_FIELDS, params={}))
    print('--------- Result one by one -----------')
    print(creatives)


def get_creatives_using_batch_api():
    session = FacebookSession(
        app_id,
        app_secret,
        access_token,
    )
    api = FacebookAdsApi(session)
    api_batch = api.new_batch()
    creatives = []

    def callback(result):
        creatives.append(result.json())  # inspecting 'result' with the debugger here, only has the id :-(

    for creative_id in creative_ids:
        c = AdCreative(creative_id)
        c.remote_read(fields=CREATIVE_FIELDS, params={}, batch=api_batch, success=callback)
    api_batch.execute()
    print('--------- Result with batch ------------')
    print(json.dumps(creatives, indent=4))



get_creatives_one_by_one()  # it works!
get_creatives_using_batch_api()  # it only gives me ids
```

