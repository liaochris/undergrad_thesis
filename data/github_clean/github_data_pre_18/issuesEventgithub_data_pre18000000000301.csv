10847,IssuesEvent,2016-03-03 11:38:58+00:00,21303988,pycontribs/jira,7759548,k0ste,1846087,pycontribs,opened,issue.update data format trouble,[],[],0,"Hi.

Error on code or documentation. See the example. The correct format is:

```python
    issue.update(fields={""customfield_12601"":[""Cactus""]})
```

Script:
```python
#!/usr/bin/python2
# -*- coding: utf-8 -*-

import os
from optparse import OptionParser

def updater(key, component, sup):
    issue = jira.issue(key)
    '''python jira documentation'''
    issue.update(fields={""customfield_12601"":""Cactus""})
    '''JIRA API documentation'''
    issue.update(fields={ ""customfield_12601"": [{""value"":""Cactus""}] })

def main():
    '''Check jira module installed or not'''
    try:
        from jira import JIRA,JIRAError
    except ImportError:
        print 'python-jira not found, please install it'
        raise SystemExit

    parser = OptionParser(usage='%prog -s http://localhost/jria -u admin -p admin', version='%prog 0.1')
    parser.add_option('-s', '--server', type='string', dest='jira_server', help='JIRA instance')
    parser.add_option('-u', '--username', type='string', dest='jira_username', default='admin', help='Username of JIRA account for auth basic [default: %default]')
    parser.add_option('-p', '--password', type='string', dest='jira_password', default='admin', help='Password of JIRA account for auth basic [default: %default]')
    (options, args) = parser.parse_args()

    if not options.jira_server or not options.jira_username or not options.jira_password:
        parser.print_help()
        raise SystemExit

    global jira
    global JIRAError
    try:
        jira = JIRA(server=options.jira_server, basic_auth=(options.jira_username, options.jira_password))
    except JIRAError:
        print 'Can\'t connet to JIRA on: \'%s\' with username \'%s\' and password \'%s\'' % (options.jira_server, options.jira_username, options.jira_password)
        raise SystemExit

    key = 'SUPPLY-6259'
    comp = 'CACTUS'
    sup = 'Cactus'
    updater(key, comp, sup)

if __name__ == ""__main__"":
  main()
```

