My code is below:

`from durable.lang import *
from flask import Flask
app = Flask(__name__)
@app.route('/test/1', methods=['POST'])
def test():
    return ""Hello, cool!""

if __name__ == '__main__':
    app.run(debug=True)
with ruleset('test'):
    # antecedent
    @when_all(m.subject == 'World')
    def say_hello(c):
        # consequent
        print('Hello World {0}'.format(c.m.subject))

    @when_start
    def start(host):
        host.post('test', {'id': 1, 'sid': 1, 'subject': 'World'})
run_all()

`

