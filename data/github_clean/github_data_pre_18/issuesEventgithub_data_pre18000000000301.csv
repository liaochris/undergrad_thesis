#3  0x000344c4 in SaSi_RndInstantiateOrReseed.part.0.constprop.4 ()
#4  0x0003461c in CRYS_RndInit ()
#5  0x000333fe in nrf5CryptoInit ()
    at /home/chenshu/code/openthread/examples/../third_party/mbedtls/../../third_party/NordicSemiconductor/libraries/crypto/cc310_mbedtls.c:55
#6  0x0001fe5c in PlatformInit (argc=argc@entry=0, argv=argv@entry=0x0 <__isr_vector>)
    at /home/chenshu/code/openthread/examples/../examples/platforms/nrf52840/platform.c:86
#7  0x000002c6 in main (argc=0, argv=0x0 <__isr_vector>) at /home/chenshu/code/openthread/examples/../examples/apps/cli/main.c:68
```

#2897 avoid the issue by removing the cc310 reinitialization during pseudo reset.",{},{}
