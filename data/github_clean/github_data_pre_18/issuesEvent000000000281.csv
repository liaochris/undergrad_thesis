8000,IssuesEvent,2017-05-12 12:24:16+00:00,648332,assimp/assimp,8568946,DafabHoid,265533,assimp,opened,Mismatched operator delete in RemoveVCProcess.cpp,[],[],0,"When using valgrind I detected an error when importing a file (a COLLADA file in this case) with the parameter ""aiProcess_RemoveComponent"" and property ""aiComponent_COLORS"" set for ""AI_CONFIG_PP_RVC_FLAGS"" in the importer:

> ==2525== Mismatched free() / delete / delete []
==2525==    at 0x4C2F25B: operator delete(void*) (in /usr/lib/valgrind/vgpreload_memcheck-amd64-linux.so)
==2525==    by 0x5EF5749: Assimp::RemoveVCProcess::ProcessMesh(aiMesh*) (RemoveVCProcess.cpp:308)
==2525==    by 0x5EF53B4: Assimp::RemoveVCProcess::Execute(aiScene*) (RemoveVCProcess.cpp:215)
==2525==    by 0x5E98640: Assimp::BaseProcess::ExecuteOnScene(Assimp::Importer*) (BaseProcess.cpp:80)
==2525==    by 0x5E9FBAE: Assimp::Importer::ApplyPostProcessing(unsigned int) (Importer.cpp:802)
==2525==    by 0x5E9F53C: Assimp::Importer::ReadFile(char const*, unsigned int) (Importer.cpp:711)
==2525==    by 0x16CDE5: Assimp::Importer::ReadFile(std::__cxx11::basic_string<char, std::char_traits<char>, std::allocator<char> > const&, unsigned int) (Importer.hpp:637)
---- my code ---
==2525==  Address 0x12e11460 is 0 bytes inside a block of size 46,416 alloc'd
==2525==    at 0x4C2E8BF: operator new[](unsigned long) (in /usr/lib/valgrind/vgpreload_memcheck-amd64-linux.so)
==2525==    by 0x5F48946: Assimp::ColladaLoader::CreateMesh(Assimp::ColladaParser const&, Assimp::Collada::Mesh const*, Assimp::Collada::SubMesh const&, Assimp::Collada::Controller const*, unsigned long, unsigned long) (ColladaLoader.cpp:654)
==2525==    by 0x5F47BB9: Assimp::ColladaLoader::BuildMeshesForNode(Assimp::ColladaParser const&, Assimp::Collada::Node const*, aiNode*) (ColladaLoader.cpp:539)
==2525==    by 0x5F464AE: Assimp::ColladaLoader::BuildHierarchy(Assimp::ColladaParser const&, Assimp::Collada::Node const*) (ColladaLoader.cpp:262)
==2525==    by 0x5F46391: Assimp::ColladaLoader::BuildHierarchy(Assimp::ColladaParser const&, Assimp::Collada::Node const*) (ColladaLoader.cpp:250)
==2525==    by 0x5F45D0B: Assimp::ColladaLoader::InternReadFile(std::__cxx11::basic_string<char, std::char_traits<char>, std::allocator<char> > const&, aiScene*, Assimp::IOSystem*) (ColladaLoader.cpp:176)
