开了一个mod，用于接入自有行情数据
核心代码：

# -*- coding: utf-8 -*-


import six
from datetime import date
from dateutil.relativedelta import relativedelta
from rqalpha.data.base_data_source import BaseDataSource
import pandas as pd

class LocalDataSource(BaseDataSource):

    csv_df = None

    def __init__(self, path):
        LocalDataSource.csv_df = self.read_cvs_as_df(""C:/Users/AA/Desktop/stock.csv"")
        super(LocalDataSource, self).__init__(path)

    @staticmethod
    def read_cvs_as_df(csv_path):
        data = pd.read_csv(csv_path, delimiter=',', index_col='index', encoding='utf-8')
        data['date'] = pd.to_datetime(data['date'], format='%Y%m%d')
        return data

    @staticmethod
    def get_bar_data_from_df(code, start, end):
        code_df = LocalDataSource.csv_df.loc[[code]]
        code_df.set_index('date', inplace=True)
        code_df.sort_index(inplace=True)
        code_period_df = code_df.loc[pd.to_datetime(start): pd.to_datetime(end)]
        code_period_df.reset_index(inplace=True)
        print ""---------------get_bar_data_from_df start--------------""
        print code_period_df
        print ""---------------get_bar_data_from_df end----------------""
        return code_period_df

    @staticmethod
    def get_local_bar_data(instrument, start_dt, end_dt):
        order_book_id = instrument.order_book_id
        code = order_book_id.replace(""XSHE"", ""SZ"").replace(""XSHG"", ""SH"")
        print code
        return LocalDataSource.get_bar_data_from_df(code, start=start_dt.strftime('%Y-%m-%d'),
                                                    end=end_dt.strftime('%Y-%m-%d'))

    def get_bar(self, instrument, dt, frequency):
        if frequency != '1d':
            return super(LocalDataSource, self).get_bar(instrument, dt, frequency)

        bar_data = self.get_local_bar_data(instrument, dt, dt)

        if bar_data is None or bar_data.empty:
            return super(LocalDataSource, self).get_bar(instrument, dt, frequency)
        else:
            print ""----------------get bar start-------------""
            print bar_data.iloc[0].to_dict()
            print ""----------------get bar end---------------""
            return bar_data.iloc[0].to_dict()

    def history_bars(self, instrument, bar_count, frequency, fields, dt,
                     skip_suspended=True, include_now=False,
                     adjust_type='pre', adjust_orig=None):
        if frequency != '1d' or not skip_suspended:
            return super(LocalDataSource, self).history_bars(instrument, bar_count, frequency, fields, dt,
                                                             skip_suspended)

        start_dt_loc = self.get_trading_calendar().get_loc(
            dt.replace(hour=0, minute=0, second=0, microsecond=0)) - bar_count + 1
        start_dt = self.get_trading_calendar()[start_dt_loc]

        bar_data = self.get_local_bar_data(instrument, start_dt, dt)

        if bar_data is None or bar_data.empty:
            return super(LocalDataSource, self).history_bars(instrument, bar_count, frequency, fields, dt,
                                                             skip_suspended)
        else:
            if isinstance(fields, six.string_types):
                fields = [fields]
            fields = [field for field in fields if field in bar_data.columns]
            return bar_data[fields].as_matrix()

    def available_data_range(self, frequency):
        return date(2005, 1, 1), date.today() - relativedelta(days=1)


