        batch_loss = dynet.average(loss_arr)
        batch_loss.backward()
        trainer.update()


        if epoch % FLAGS.display_step == 0:
            prob_arr = [prob.value() for prob in prob_arr]
            ks, roc_auc, accuracy = mm.mdl_eval_binary(prob_arr, (np.array(y_train)[:,1]).tolist())
            train_ret = ""[TRN]Epoch:%04d, loss=%.9f, ks=%.4f,roc_auc=%.4f"" \
                        % (epoch, batch_loss.value(), ks, roc_auc)

            logger.info(train_ret)`
